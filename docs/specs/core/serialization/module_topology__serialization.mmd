    %% Serialization_Header embedded in 32-bit UUID structs
    Entity *-- Serialization_Header : first field
    UI_Element *-- Serialization_Header : first field
    Graphics_Window *-- Serialization_Header : first field
    Game_Action *-- Serialization_Header : first field

    %% Serialization_Header__UUID_64 embedded in 64-bit UUID structs
    Chunk *-- Serialization_Header__UUID_64 : first field
    Global_Space *-- Serialization_Header__UUID_64 : first field
    Collision_Node *-- Serialization_Header__UUID_64 : first field

    %% Identifiers generates UUIDs using randomizer
    Identifiers --> Repeatable_Psuedo_Random : uses for UUID generation

    %% Hashing depends on Serialization_Header for array operations
    Hashing --> Serialization_Header : operates on contiguous arrays
    Hashing --> Serialization_Header__UUID_64 : operates on contiguous arrays (64-bit)
    Hashing --> Identifiers : uses for UUID generation and validation

    %% Serialization_Pool wraps contiguous arrays and delegates to Hashing
    Serialization_Pool *-- Serialization_Header : p_headers (backing array)
    Serialization_Pool --> Hashing : delegates dehash and allocation

    %% Serialized_Field contains a Serialization_Header (via union) and a data pointer
    Serialized_Field *-- Serialization_Header : _serialization_header (union overlay)
    Serialized_Field --> Serialization_Header : links against contiguous arrays

    %% Typed aliases for Serialized_Field
    Serialized_Item_Stack_Ptr ..|> Serialized_Field : typedef
    Serialized_Inventory_Ptr ..|> Serialized_Field : typedef
    Serialized_Entity_Ptr ..|> Serialized_Field : typedef
    Serialized_Chunk_Ptr ..|> Serialized_Field : typedef

    %% Serialization_Request references Serialization_Header and uses flags
    Serialization_Request *-- Serialization_Request_Flags : serialization_request_flags
    Serialization_Request --> Serialization_Header : p_serialization_header

    %% PLATFORM_File_System_Context pools Serialization_Requests
    PLATFORM_File_System_Context *-- "N" Serialization_Request : platform pool

    %% Game_Directory depends on Game for save/load
    Game_Directory --> Game : operates on
    Game_Directory --> PLATFORM_File_System_Context : uses platform I/O

    %% Serialization_Request lifecycle managed via platform context
    Serialization_Request --> PLATFORM_File_System_Context : deactivate closes file/frees bitmap
