    %% Ownership: Game owns World
    Game *-- World : owns via pM_world

    %% World owns all major sub-components
    World *-- Camera : owns
    World *-- Region_Manager : owns
    World *-- Global_Space_Manager : owns
    World *-- Chunk_Pool : owns
    World *-- Structure_Manager : owns
    World *-- Tile_Logic_Table : owns
    World *-- Chunk_Generator_Table : owns
    World --> Graphics_Window : p_graphics_window_for__world

    %% Region_Manager owns Regions
    Region_Manager *-- "0..4" Region : regions array

    %% Global_Space_Manager owns Global_Spaces
    Global_Space_Manager *-- "N" Global_Space : global_spaces array
    Global_Space *-- Global_Space_Flags__u8 : global_space_flags__u8

    %% Global_Space references Chunk and Collision_Node
    Global_Space --> Chunk : p_chunk
    Global_Space --> Collision_Node : p_collision_node

    %% Local_Space_Manager owns Local_Spaces
    Local_Space_Manager *-- "64" Local_Space : local_spaces array

    %% Local_Space references Global_Space and neighbors
    Local_Space --> Global_Space : p_global_space
    Local_Space --> Local_Space : p_local_space__north/east/south/west/above/below

    %% Chunk_Pool owns Chunks
    Chunk_Pool *-- "N" Chunk : chunks array
    Chunk *-- Chunk_Flags : chunk_flags
    Chunk *-- "128" Tile : tiles array

    %% Tile_Logic_Table owns Tile_Logic_Records
    Tile_Logic_Table *-- "N" Tile_Logic_Record : tile_logic_table_data
    Tile_Logic_Record *-- Tile_Logic_Flags__u16 : tile_logic_flags__u8

    %% Chunk_Generator_Table owns generator process array
    Chunk_Generator_Table *-- "N" m_Process : M_process__chunk_generators

    %% Structure_Manager owns Rooms and Structures
    Structure_Manager *-- "128" Room : rooms pool
    Structure_Manager *-- "16" Structure : structures pool

    %% Structure references Rooms
    Structure --> "0..8" Room : ptr_array_of__rooms

    %% Site references Structures
    Site --> "0..N" Structure : ptr_array_of__structures_in__site

    %% Region tracks serialized chunks and sites
    Region ..> Global_Space : bitmap tracks serialization
    Region ..> Site : bitmap tracks sites

    %% Camera can follow an entity by UUID
    Camera ..> Entity_Manager : uuid_of__target__u32 references

    %% Structure_Tile is a helper for generation
    Structure_Tile .. Structure : used during generation
