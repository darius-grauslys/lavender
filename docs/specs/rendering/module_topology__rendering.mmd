    %% Ownership: Game owns Gfx_Context
    Game *-- Gfx_Context : owns

    %% Gfx_Context owns all subsystem managers
    Gfx_Context *-- Graphics_Window_Manager : owns
    Gfx_Context *-- Aliased_Texture_Manager : owns
    Gfx_Context *-- Sprite_Context : owns
    Gfx_Context *-- Font_Manager : owns
    Gfx_Context *-- UI_Context : owns
    Gfx_Context *-- UI_Tile_Map_Manager : owns
    Gfx_Context --> PLATFORM_Gfx_Context : p_PLATFORM_gfx_context

    %% Graphics_Window_Manager owns Graphics_Window pool
    Graphics_Window_Manager *-- "0..8" Graphics_Window : graphics_windows pool

    %% Graphics_Window composition
    Graphics_Window *-- Graphics_Window_Flags__u8 : graphics_window__flags
    Graphics_Window --> PLATFORM_Graphics_Window : p_PLATFORM_gfx_window
    Graphics_Window --> Graphics_Window : graphics_window__parent__uuid (parent-child)

    %% Graphics_Window references managers by UUID (ownership or sharing)
    Graphics_Window ..> Sprite_Manager : uuid_of__sprite_manager references
    Graphics_Window ..> UI_Manager : uuid_of__ui_manager references
    Graphics_Window ..> Hitbox_Manager_Instance : uuid_of__hitbox_manager references

    %% Aliased_Texture_Manager owns Aliased_Texture pool
    Aliased_Texture_Manager *-- "0..128" Aliased_Texture : aliased_textures pool

    %% Aliased_Texture wraps Texture
    Aliased_Texture *-- Texture : texture

    %% Texture wraps platform handle and flags
    Texture --> PLATFORM_Texture : p_PLATFORM_texture
    Texture *-- Texture_Flags : texture_flags

    %% Sprite_Context owns Sprite_Manager pool and animation registries
    Sprite_Context *-- "0..N" Sprite_Manager : pM_sprite_managers (heap pool)
    Sprite_Context *-- "N" Sprite_Animation : sprite_animations registry
    Sprite_Context *-- "N" Sprite_Animation_Group_Set : sprite_animation_groups registry

    %% Sprite_Manager owns Sprite pool and render records
    Sprite_Manager *-- "0..N" Sprite : pM_pool_of__sprites (heap pool)
    Sprite_Manager *-- "0..N" Sprite_Render_Record : pM_sprite_render_records (heap)

    %% Sprite_Render_Record references Sprite
    Sprite_Render_Record --> Sprite : p_sprite

    %% Sprite composition
    Sprite *-- Sprite_Animation : animation (embedded)
    Sprite *-- Sprite_Flags : sprite_flags__u8
    Sprite *-- Texture : texture_for__sprite_to__sample
    Sprite *-- Texture : texture_of__sprite
    Sprite --> PLATFORM_Sprite : p_PLATFORM_sprite

    %% Sprite_Animation uses flags
    Sprite_Animation *-- Sprite_Animation_Flags__u3 : sprite_animation__flags__u3

    %% Font_Manager owns Font pool
    Font_Manager *-- "0..8" Font : fonts pool

    %% Font composition
    Font *-- "256" Font_Letter : font_lookup_table
    Font *-- Texture : texture_of__font
    Font *-- Font_Flags : font_flags

    %% Typer references Font and render targets
    Typer --> Font : p_font
    Typer --> Texture : texture_of__typer_target (union)
    Typer --> PLATFORM_Graphics_Window : p_PLATFORM_graphics_window__typer_target (union)

    %% GFX_CONTEXT_Helpers uses multiple subsystems
    GFX_CONTEXT_Helpers ..> Graphics_Window_Manager : allocates windows
    GFX_CONTEXT_Helpers ..> Graphics_Window : configures resources
    GFX_CONTEXT_Helpers ..> UI_Manager : allocates for window
    GFX_CONTEXT_Helpers ..> Sprite_Manager : allocates for window
