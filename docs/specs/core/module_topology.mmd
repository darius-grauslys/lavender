    %% ===== Game owns top-level subsystems =====
    Game *-- Gfx_Context : owns
    Game *-- Hitbox_Context : owns
    Game *-- Process_Manager : owns
    Game *-- Scene_Manager : owns
    Game *-- Sort_List_Manager : owns
    Game *-- Path_List_Manager : owns
    Game *-- Input : owns (fallback)
    Game *-- Session_Token : owns
    Game *-- Game_Action_Logic_Table : owns
    Game *-- "3" Log : owns (global, local, system)
    Game *-- "3" Timer__u32 : owns (tick, seconds, nanoseconds)
    Game *-- Game_Flags__u32 : game_flags__u32
    Game *-- World : owns via pM_world
    Game *-- "0..*" Client : owns pool via pM_clients
    Game --> TCP_Socket_Manager : pM_tcp_socket_manager (optional)
    Game --> PLATFORM_Audio_Context : p_PLATFORM_audio_context
    Game --> PLATFORM_File_System_Context : p_PLATFORM_file_system_context

    %% ===== Gfx_Context owns rendering subsystems =====
    Gfx_Context *-- Graphics_Window_Manager : owns
    Gfx_Context *-- Aliased_Texture_Manager : owns
    Gfx_Context *-- UI_Context : owns
    Gfx_Context *-- Sprite_Context : owns
    Gfx_Context *-- Font_Manager : owns
    Gfx_Context --> PLATFORM_Gfx_Context : p_PLATFORM_gfx_context

    %% ===== Graphics subsystem internals =====
    Graphics_Window_Manager *-- "0..*" Graphics_Window : owns
    Graphics_Window --> PLATFORM_Graphics_Window : platform backing
    Aliased_Texture_Manager *-- Repeatable_Psuedo_Random : texture UUID generation

    %% ===== UI subsystem =====
    UI_Context *-- UI_Manager : owns
    UI_Manager *-- "0..*" UI_Element : pM_ui_element_pool
    UI_Manager *-- Repeatable_Psuedo_Random : UUID generation

    %% ===== World owns world subsystems =====
    World *-- Collision_Node_Pool : owns
    World *-- Global_Space_Manager : owns
    World *-- Entity_Manager : owns
    World *-- Inventory_Manager : owns
    World *-- Item_Manager : owns
    World *-- Repeatable_Psuedo_Random : world generation

    %% ===== World internals =====
    Global_Space_Manager *-- "0..*" Global_Space : owns
    Global_Space --> Collision_Node_Pool : p_collision_node references node in pool
    Entity_Manager *-- Repeatable_Psuedo_Random : entity UUID generation

    %% ===== Client owns its subsystems =====
    Client *-- Serialization_Header : _serialization_header
    Client *-- "2" Game_Action_Manager : owns (inbound + outbound)
    Client *-- Local_Space_Manager : owns
    Client *-- Input : owns (input_of__client)
    Client *-- Client_Flags__u16 : client_flags__u16

    %% ===== Client interactions =====
    Game_Action_Manager *-- Repeatable_Psuedo_Random : game action UUID generation
    Client --> Game_Action : dispatches and receives

    %% ===== Networking =====
    TCP_Socket_Manager --> PLATFORM_TCP_Context : platform backing

    %% ===== Process Manager =====
    Process_Manager *-- Repeatable_Psuedo_Random : process UUID generation

    %% ===== Audio =====
    PLATFORM_Audio_Context *-- "0..*" Audio_Effect : manages
    Audio_Effect *-- Timer__u32 : timer_for__audio

    %% ===== Serialization =====
    PLATFORM_File_System_Context *-- "0..*" Serialization_Request : owns pool
    Serialization_Request --> Serialization_Header : p_serialization_header
