    %% ===== Ownership Relationships =====

    %% Game owns the logic table and process manager
    Game *-- Game_Action_Logic_Table : owns
    Game *-- Process_Manager : owns

    %% Client owns two Game_Action_Managers
    Client *-- "2" Game_Action_Manager : inbound + outbound

    %% Game_Action_Manager owns a pool of Game_Actions
    Game_Action_Manager *-- "MAX_QUANTITY_OF__GAME_ACTIONS" Game_Action : game_actions pool

    %% Game_Action_Logic_Table owns entries indexed by kind
    Game_Action_Logic_Table *-- "Game_Action_Kind__Unknown" Game_Action_Logic_Entry : indexed by kind

    %% Game_Action composition
    Game_Action *-- Game_Action_Flags : game_action_flags
    Game_Action *-- Game_Action_Kind : the_kind_of_game_action__this_action_is

    %% Game_Action_Logic_Entry references m_Process handlers
    Game_Action_Logic_Entry --> Process : spawns via dispatch

    %% Process references Game_Action as process data
    Process --> Game_Action : p_process_data

    %% ===== Registrar populates the logic table =====
    Game_Action_Registrar ..> Game_Action_Logic_Table : populates entries

    %% ===== Payload kind classes are union members of Game_Action =====
    Game_Action --> GA_TCP_Connect__Begin : union payload
    Game_Action --> GA_TCP_Connect : union payload
    Game_Action --> GA_TCP_Connect__Accept : union payload
    Game_Action --> GA_TCP_Connect__Reject : union payload
    Game_Action --> GA_TCP_Delivery : union payload
    Game_Action --> GA_Global_Space__Request : union payload
    Game_Action --> GA_Global_Space__Resolve : union payload
    Game_Action --> GA_Global_Space__Store : union payload
    Game_Action --> GA_Entity__Spawn : union payload
    Game_Action --> GA_Entity__Get : union payload
    Game_Action --> GA_Hitbox__Set_Position : union payload
    Game_Action --> GA_Input : union payload
    Game_Action --> GA_World__Load_World : union payload
    Game_Action --> GA_World__Load_Client : union payload
    Game_Action --> GA_Bad_Request : union payload

    %% ===== Hitbox AABB process handler =====
    GA_Hitbox__Set_Position ..> GA_Hitbox__AABB_Process : registered as m_Process for AABB

    %% ===== TCP Delivery used by multi-packet transfers =====
    GA_TCP_Delivery ..> Serialization_Request : fragment reassembly
    GA_Global_Space__Request ..> GA_TCP_Delivery : chunk data via fragments
    GA_Entity__Get ..> GA_TCP_Delivery : entity data via fragments
