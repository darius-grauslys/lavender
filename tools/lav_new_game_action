#!/bin/bash
#
# lav_new_game_action
#
# Deterministically generated script for creating game action type headers.
# This script creates the directory structure and header files for a new
# game action type under ./include/game_action/types/implemented/
#
# Usage: lav_new_game_action <relative/path/to/leaf.h>
#
# Example: lav_new_game_action collisions/aabb/update__pos_vec_i32.h
#   Creates:
#     include/game_action/types/implemented/collisions/ga_types__collisions.h
#     include/game_action/types/implemented/collisions/aabb/ga_types__collisions__aabb.h
#     include/game_action/types/implemented/collisions/aabb/ga_type__collisions__aabb__update__pos_vec_i32.h
#

set -e

##############################################################################
# Verbosity & Argument Parsing
##############################################################################

VERBOSE=false

POSITIONAL_ARGS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        -v|--verbose)
            VERBOSE=true
            shift
            ;;
        -*)
            echo "Unknown option: $1" >&2
            echo "Usage: $0 [-v|--verbose] <relative/path/to/leaf.h>" >&2
            exit 1
            ;;
        *)
            POSITIONAL_ARGS+=("$1")
            shift
            ;;
    esac
done

function log_verbose() {
    if [ "$VERBOSE" = true ]; then
        echo "$@"
    fi
}

##############################################################################
# Validation
##############################################################################

if [ "${#POSITIONAL_ARGS[@]}" -ne 1 ]; then
    echo "Usage: $0 [-v|--verbose] <relative/path/to/leaf.h>" >&2
    echo "Example: $0 collisions/aabb/update__pos_vec_i32.h" >&2
    exit 1
fi

REL_PATH="${POSITIONAL_ARGS[0]}"

if [[ "$REL_PATH" != *.h ]]; then
    echo "Error: path must end with .h"
    exit 1
fi

# Strip the .h suffix for processing
REL_PATH_NO_EXT="${REL_PATH%.h}"

# Split path into components
IFS='/' read -ra PARTS <<< "$REL_PATH_NO_EXT"

if [ "${#PARTS[@]}" -lt 1 ]; then
    echo "Error: path must have at least one component."
    exit 1
fi

BASE_DIR="./include/game_action/types/implemented"

##############################################################################
# Helper: build the accumulated name prefix from path components
#   e.g. components=(collisions aabb) => collisions__aabb
##############################################################################
function build_prefix() {
    local count=$1
    shift
    local components=("$@")
    local result=""
    for (( i=0; i<count; i++ )); do
        if [ -z "$result" ]; then
            result="${components[$i]}"
        else
            result="${result}__${components[$i]}"
        fi
    done
    echo "$result"
}

##############################################################################
# Helper: convert a name like "collisions__aabb" to upper case "COLLISIONS__AABB"
##############################################################################
function to_upper() {
    echo "$1" | tr '[:lower:]' '[:upper:]'
}

##############################################################################
# Helper: convert a prefix like "collisions__aabb" to a struct-style name
#   "GA_Collisions__AABB" — we capitalize each segment after splitting on __
#   Actually looking at the codebase:
#     collisions => GA_Collisions
#     aabb => GA_AABB
#     tcp__connect_begin => GA_TCP_Connect__Begin
#   The convention is: each path component becomes a PascalCase/Upper segment.
#   We'll do: split on __, capitalize first letter of each _ separated word.
##############################################################################
function to_struct_name() {
    local prefix="$1"
    local kind="$2"  # "union" or "type"
    # Split on __ (double underscore) to get path-level segments
    local IFS_OLD="$IFS"
    local result="GA"
    # We split the prefix by __ to get the path-level segments
    # Then each segment's internal _ separated words get capitalized
    local segments=()
    local tmp="$prefix"
    while [[ "$tmp" == *"__"* ]]; do
        local seg="${tmp%%__*}"
        segments+=("$seg")
        tmp="${tmp#*__}"
    done
    segments+=("$tmp")

    for seg in "${segments[@]}"; do
        # Split segment by single _ and capitalize each word
        local words
        IFS='_' read -ra words <<< "$seg"
        local capitalized=""
        for word in "${words[@]}"; do
            if [ -z "$word" ]; then
                continue
            fi
            # Check if the word is all-caps-worthy (like "aabb", "tcp", "ip")
            # Heuristic: if 4 chars or fewer and looks like an acronym, uppercase all
            local len=${#word}
            if [ "$len" -le 4 ]; then
                capitalized="${capitalized}_$(to_upper "$word")"
            else
                capitalized="${capitalized}_$(echo "${word:0:1}" | tr '[:lower:]' '[:upper:]')${word:1}"
            fi
        done
        # Remove leading _
        capitalized="${capitalized#_}"
        result="${result}_${capitalized}"
    done

    IFS="$IFS_OLD"
    echo "$result"
}

##############################################################################
# Helper: generate a union (intermediate) header file
#   These are like ga_types__collisions.h or ga_types__aabb.h
##############################################################################
function generate_union_header() {
    local filepath="$1"
    local prefix="$2"          # e.g. "collisions" or "collisions__aabb"
    local guard_name="$3"      # e.g. "GA_TYPES__COLLISIONS_H"
    local struct_name="$4"     # e.g. "GA_Collisions"
    local injection_tag="$5"   # e.g. "COLLISIONS" or "COLLISIONS__AABB"
    local impl_guard="${guard_name%_H}_IMPL_H"

    cat > "$filepath" << HEADER_EOF
/// This file is deterministically generated. Do not edit manually
/// outside of designated GEN-BEGIN / GEN-END regions.
#ifndef ${guard_name}
#define ${guard_name}
#define GA_TYPE_CONTEXT

#ifndef DEFINES_H
#include <defines.h>
#endif

#include <util/custom_type_macro.h>

LAV_UNION__BEGIN(${struct_name}){

#ifndef INJECTION_ACTIVE
#define INJECTION_ACTIVE
#define INJECTION_ACTIVE__${injection_tag}
#endif
    struct {
// FIELDS-BEGIN
// FIELDS-END
        union {
// GEN-BEGIN
// GEN-END
        };
    };

#ifdef INJECTION_ACTIVE__${injection_tag}
#undef INJECTION_ACTIVE__${injection_tag}
#undef INJECTION_ACTIVE
#endif

} ${struct_name};

#undef GA_TYPE_CONTEXT
#endif // Header guard

#ifndef INJECTION_ACTIVE
#ifndef ${impl_guard}
#define ${impl_guard}

// GEN-IMPL-BEGIN
// GEN-IMPL-END

#endif // Impl Header guard
#endif // INJECTION_ACTIVE
HEADER_EOF
}

##############################################################################
# Helper: generate a leaf (type) header file
#   These are like ga_type__tcp__connect_begin.h
##############################################################################
function generate_leaf_header() {
    local filepath="$1"
    local prefix="$2"          # e.g. "collisions__aabb__update__pos_vec_i32"
    local guard_name="$3"      # e.g. "GA_TYPE__COLLISIONS__AABB__UPDATE__POS_VEC_I32_H"
    local struct_name="$4"     # e.g. "GA_Collisions__AABB__Update__Pos_Vec_I32"
    local impl_guard="$5"      # e.g. "GA_TYPE__COLLISIONS__AABB__UPDATE__POS_VEC_I32_IMPL_H"

    cat > "$filepath" << HEADER_EOF
/// This file is deterministically generated. Do not edit manually
/// outside of designated GEN / FIELDS regions.
#if !defined(${guard_name}) \\
    || defined(INJECTION_ACTIVE)

#ifndef INJECTION_ACTIVE
#define ${guard_name}
#endif
#define GA_TYPE_CONTEXT

#ifndef DEFINES_H
#include <defines.h>
#endif

#include <util/custom_type_macro.h>

LAV_TYPE__BEGIN(${struct_name}){
// FIELDS-BEGIN
// FIELDS-END
} ${struct_name};

#undef GA_TYPE_CONTEXT
#endif // Header guard

#ifndef INJECTION_ACTIVE
#ifndef ${impl_guard}
#define ${impl_guard}

// GEN-IMPL-BEGIN
// GEN-IMPL-END

#endif // Impl Header guard
#endif // INJECTION_ACTIVE
HEADER_EOF
}

##############################################################################
# Helper: ensure an #include line exists between GEN-BEGIN and GEN-END
#   in an existing union header file. Returns 0 if added, 1 if already present.
##############################################################################
function ensure_include_in_gen_region() {
    local filepath="$1"
    local include_line="$2"

    # Check if the include already exists between GEN-BEGIN and GEN-END
    local in_region=0
    local found=0
    while IFS= read -r line; do
        if [[ "$line" == *"// GEN-BEGIN"* ]]; then
            in_region=1
            continue
        fi
        if [[ "$line" == *"// GEN-END"* ]]; then
            in_region=0
            continue
        fi
        if [ "$in_region" -eq 1 ]; then
            # Trim whitespace for comparison
            local trimmed
            trimmed="$(echo "$line" | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//')"
            if [ "$trimmed" = "$include_line" ]; then
                found=1
                break
            fi
        fi
    done < "$filepath"

    if [ "$found" -eq 1 ]; then
        return 1
    fi

    # Insert the include line before // GEN-END
    local escaped_include
    escaped_include="$(echo "$include_line" | sed 's/[&/\]/\\&/g')"
    sed -i "0,/\/\/ GEN-END/{s|// GEN-END|${escaped_include}\n// GEN-END|}" "$filepath"
    return 0
}

##############################################################################
# Helper: parse fields from a leaf header between FIELDS-BEGIN and FIELDS-END
#   Outputs lines of: TYPE NAME
##############################################################################
function parse_fields() {
    local filepath="$1"
    local in_region=0
    while IFS= read -r line; do
        if [[ "$line" == *"// FIELDS-BEGIN"* ]]; then
            in_region=1
            continue
        fi
        if [[ "$line" == *"// FIELDS-END"* ]]; then
            in_region=0
            continue
        fi
        if [ "$in_region" -eq 1 ]; then
            # Try to parse a field declaration: TYPE NAME;
            local trimmed
            trimmed="$(echo "$line" | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//')"
            # Skip empty lines and comments
            if [ -z "$trimmed" ] || [[ "$trimmed" == "//"* ]] || [[ "$trimmed" == "/*"* ]]; then
                continue
            fi
            # Remove trailing semicolon
            trimmed="${trimmed%;}"
            # Split into type and name — last word is the name, rest is type
            local field_name
            field_name="$(echo "$trimmed" | awk '{print $NF}')"
            local field_type
            field_type="$(echo "$trimmed" | awk '{$NF=""; print}' | sed 's/[[:space:]]*$//')"
            if [ -n "$field_name" ] && [ -n "$field_type" ]; then
                echo "${field_type}|${field_name}"
            fi
        fi
    done < "$filepath"
}

##############################################################################
# Helper: check if an accessor comment marker exists in GEN-IMPL region
##############################################################################
function accessor_exists_in_impl() {
    local filepath="$1"
    local accessor_marker="$2"  # e.g. "// ACCESSOR: field_name"

    local in_region=0
    while IFS= read -r line; do
        if [[ "$line" == *"// GEN-IMPL-BEGIN"* ]]; then
            in_region=1
            continue
        fi
        if [[ "$line" == *"// GEN-IMPL-END"* ]]; then
            in_region=0
            continue
        fi
        if [ "$in_region" -eq 1 ]; then
            local trimmed
            trimmed="$(echo "$line" | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//')"
            if [ "$trimmed" = "$accessor_marker" ]; then
                return 0
            fi
        fi
    done < "$filepath"
    return 1
}

##############################################################################
# Helper: generate accessor functions for a field and insert before GEN-IMPL-END
##############################################################################
function generate_accessors_for_field() {
    local filepath="$1"
    local struct_name="$2"
    local field_type="$3"
    local field_name="$4"
    local header_kind="$5"  # "union" or "leaf"

    local lower_struct
    lower_struct="$(echo "$struct_name" | tr '[:upper:]' '[:lower:]')"

    local accessor_block=""

    # Check if getter accessor exists
    if ! accessor_exists_in_impl "$filepath" "// ACCESSOR: ${field_name}"; then
        if [ "$header_kind" = "union" ]; then
            accessor_block="${accessor_block}
// ACCESSOR: ${field_name}
static inline
${field_type} get_${field_name}_from__${lower_struct}(
        Game_Action *p_game_action) {
    return p_game_action
        ->${struct_name}
        .${field_name}
        ;
}"
        else
            accessor_block="${accessor_block}
// ACCESSOR: ${field_name}
static inline
${field_type} get_${field_name}_from__${lower_struct}(
        Game_Action *p_game_action) {
    return (GET_P_GAME_ACTION_PAYLOAD_AS_P(p_game_action, ${struct_name}))
        .${field_name}
        ;
}"
        fi
    fi

    # Check if pointer accessor exists
    if ! accessor_exists_in_impl "$filepath" "// ACCESSOR: p_${field_name}"; then
        if [ "$header_kind" = "union" ]; then
            accessor_block="${accessor_block}

// ACCESSOR: p_${field_name}
static inline
${field_type} *get_p_${field_name}_from__${lower_struct}(
        Game_Action *p_game_action) {
    return &p_game_action
        ->${struct_name}
        .${field_name}
        ;
}"
        else
            accessor_block="${accessor_block}

// ACCESSOR: p_${field_name}
static inline
${field_type} *get_p_${field_name}_from__${lower_struct}(
        Game_Action *p_game_action) {
    return &(GET_P_GAME_ACTION_PAYLOAD_AS_P(p_game_action, ${struct_name}))
        .${field_name}
        ;
}"
        fi
    fi

    if [ -n "$accessor_block" ]; then
        # We need to insert before // GEN-IMPL-END
        # Write accessor block to a temp file to handle multiline sed
        local tmpfile
        tmpfile=$(mktemp)
        echo "$accessor_block" > "$tmpfile"

        # Use python for reliable multiline insertion since sed struggles
        python3 -c "
import sys
marker = '// GEN-IMPL-END'
with open('${filepath}', 'r') as f:
    content = f.read()
with open('${tmpfile}', 'r') as f:
    insertion = f.read()
# Insert before the first occurrence of GEN-IMPL-END
idx = content.find(marker)
if idx != -1:
    content = content[:idx] + insertion + '\n' + content[idx:]
with open('${filepath}', 'w') as f:
    f.write(content)
"
        rm -f "$tmpfile"
    fi
}

##############################################################################
# Helper: generate the game_action .h file under ./include/game_action/implemented/
##############################################################################
function generate_game_action_header() {
    local filepath="$1"
    local leaf_prefix="$2"         # e.g. "collisions__aabb__update__pos_vec_i32"
    local leaf_struct_name="$3"    # e.g. "GA_Collisions__AABB__Update__Pos_Vec_I32"
    local guard_name="$4"          # e.g. "GAME_ACTION__COLLISIONS__AABB__UPDATE__POS_VEC_I32_H"
    local func_suffix="$5"         # e.g. "collisions__aabb__update__pos_vec_i32"
    local type_include_path="$6"   # path to the leaf type header
    local union_include_paths="$7" # newline-separated list of union type header paths
    local leaf_type_file="$8"      # absolute path to leaf type header on disk

    # Parse fields from the leaf type header to build function signatures
    local fields_params=""
    local dispatch_params=""
    local dispatch_args=""

    if [ -f "$leaf_type_file" ]; then
        local parsed_fields
        parsed_fields="$(parse_fields "$leaf_type_file")"
        if [ -n "$parsed_fields" ]; then
            while IFS= read -r field_line; do
                local ftype fnam
                ftype="$(echo "$field_line" | cut -d'|' -f1)"
                fnam="$(echo "$field_line" | cut -d'|' -f2)"
                if [ -n "$ftype" ] && [ -n "$fnam" ]; then
                    fields_params="${fields_params},
        ${ftype} ${fnam}"
                    dispatch_params="${dispatch_params},
        ${ftype} ${fnam}"
                    dispatch_args="${dispatch_args},
            ${fnam}"
                fi
            done <<< "$parsed_fields"
        fi
    fi

    # Build union include lines
    local union_includes=""
    if [ -n "$union_include_paths" ]; then
        while IFS= read -r upath; do
            if [ -n "$upath" ]; then
                union_includes="${union_includes}
#include \"${upath}\""
            fi
        done <<< "$union_include_paths"
    fi

    cat > "$filepath" << HEADER_EOF
/// This file is deterministically generated.
/// Implement the #error stubs in the corresponding .c file.
#ifndef ${guard_name}
#define ${guard_name}

#include "defines.h"
#include "defines_weak.h"
#include "game.h"
${union_includes}
#include "${type_include_path}"

void register_game_action__${func_suffix}_for__server(
        Game_Action_Logic_Table *p_game_action_logic_table);

static inline
void register_game_action__${func_suffix}_for__offline(
        Game_Action_Logic_Table *p_game_action_logic_table) {
    register_game_action__${func_suffix}_for__server(
            p_game_action_logic_table);
}

void register_game_action__${func_suffix}_for__client(
        Game_Action_Logic_Table *p_game_action_logic_table);

void initialize_game_action_for__${func_suffix}(
        Game_Action *p_game_action${fields_params});

static inline
bool dispatch_game_action__${func_suffix}(
        Game *p_game${dispatch_params}) {
    Game_Action ga;
    initialize_game_action_for__${func_suffix}(
            &ga${dispatch_args});
    return dispatch_game_action_to__server(
            p_game,
            &ga);
}

#endif
HEADER_EOF
}

