%% Module Topology: Entity System
%% Shows ownership hierarchy and relationships between entity types.

classDiagram
    direction TB

    class Game {
        +World *pM_world
    }

    class World {
        +Entity_Manager entity_manager
    }

    class Entity_Manager {
        +Entity entities[MAX_QUANTITY_OF__ENTITIES]
        +Entity *ptr_array_of__entities[MAX_QUANTITY_OF__ENTITIES]
        +Entity_Functions entity_functions[Entity_Kind__Unknown]
        +Repeatable_Psuedo_Random randomizer
        +Entity **p_ptr_entity__next_in_ptr_array
        +f_Entity_Initializer f_entity_initializer
        +initialize_entity_manager()
        +register_entity_into__entity_manager()
        +sanitize_entity_functions()
        +allocate_entity_in__entity_manager() Entity*
        +allocate_entity_with__this_uuid_in__entity_manager() Entity*
        +release_entity_from__entity_manager()
        +get_p_entity_by__uuid_from__entity_manager() Entity*
        +get_p_entity_by__index_from__entity_manager() Entity*
        +set_entity_initializer_in__entity_manager()
        +set_entity_functions()
    }

    class Entity {
        +Serialization_Header _serialization_header
        +Entity_Data entity_data
        +Entity_Functions entity_functions
        +initialize_entity()
        +serialize_entity() PLATFORM_Write_File_Error
        +deserialize_entity() PLATFORM_Read_File_Error
        +is_entity__allocated() bool
        +is_entity__enabled() bool
        +is_entity__serialized_with__hitbox() bool
        +is_entity__serialized_with__inventory() bool
        +set_entity_as__enabled()
        +set_entity_as__disabled()
        +get_kind_of__entity() Entity_Kind
        +set_m_entity_update_handler_for__entity()
    }

    class Entity_Data {
        <<implementable>>
        +Entity_Flags__u32 entity_flags
        +Entity_Kind the_kind_of__entity
    }

    class Entity_Functions {
        <<implementable>>
        +m_Entity_Handler m_entity_dispose_handler
        +m_Entity_Handler m_entity_update_handler
        +m_Entity_Handler m_entity_enable_handler
        +m_Entity_Handler m_entity_disable_handler
        +m_Entity_Serialization_Handler m_entity_serialize_handler
        +m_Entity_Deserialization_Handler m_entity_deserialize_handler
    }

    class Entity_Kind {
        <<enumeration, implementable>>
        Entity_Kind__None
        Entity_Kind__Unknown
    }

    class Entity_Flags__u32 {
        <<typedef u32>>
        +ENTITY_FLAG__IS_ENABLED
        +ENTITY_FLAG__IS_NOT_UPDATING_POSITION
        +ENTITY_FLAG__IS_NOT_UPDATING_GRAPHICS
        +ENTITY_FLAG__IS_COLLIDING
        +ENTITY_FLAG__IS_UNLOADED
        +ENTITY_FLAG__IS_HIDDEN
        +ENTITY_FLAG__IS_WITH_HITBOX__SERIALIZATION
        +ENTITY_FLAG__IS_WITH_INVENTORY__SERIALIZATION
        +ENTITY_FLAG__RESERVED_0 .. ENTITY_FLAG__RESERVED_7
        +ENTITY_FLAG__CUSTOM_0 .. ENTITY_FLAG__CUSTOM_15
    }

    class Serialization_Header {
        +Quantity__u32 size_of__struct
        +Identifier__u32 uuid
    }

    class Serialization_Request {
        +void *p_data
        +Serialization_Header *p_serialization_header
        +void *p_file_handler
        +Quantity__u32 quantity_of__file_contents
    }

    class m_Entity_Handler {
        <<function pointer>>
        (Entity*, Game*, World*) -> void
    }

    class m_Entity_Serialization_Handler {
        <<function pointer>>
        (Entity*, Game*, PLATFORM_File_System_Context*, World*, Serialization_Request*) -> PLATFORM_Write_File_Error
    }

    class m_Entity_Deserialization_Handler {
        <<function pointer>>
        (Entity*, Game*, PLATFORM_File_System_Context*, World*, Serialization_Request*) -> PLATFORM_Read_File_Error
    }

    class f_Entity_Initializer {
        <<function pointer>>
        (Game*, World*, Entity*) -> void
    }

    class Repeatable_Psuedo_Random {
        +Psuedo_Random_Seed__u32 seed__initial
        +Psuedo_Random_Seed__u32 seed__current_random
    }

    %% Ownership: Game owns World
    Game *-- World : owns via pM_world

    %% Ownership: World owns Entity_Manager
    World *-- Entity_Manager : owns

    %% Entity_Manager owns Entity pool and function table registry
    Entity_Manager *-- "MAX_QUANTITY_OF__ENTITIES" Entity : entities pool
    Entity_Manager *-- "Entity_Kind__Unknown" Entity_Functions : per-kind registry
    Entity_Manager *-- Repeatable_Psuedo_Random : randomizer
    Entity_Manager --> f_Entity_Initializer : f_entity_initializer

    %% Entity composition
    Entity *-- Serialization_Header : _serialization_header
    Entity *-- Entity_Data : entity_data
    Entity *-- Entity_Functions : entity_functions (instance copy)

    %% Entity_Data composition
    Entity_Data *-- Entity_Flags__u32 : entity_flags
    Entity_Data *-- Entity_Kind : the_kind_of__entity

    %% Entity_Functions composition
    Entity_Functions --> m_Entity_Handler : dispose, update, enable, disable
    Entity_Functions --> m_Entity_Serialization_Handler : serialize
    Entity_Functions --> m_Entity_Deserialization_Handler : deserialize

    %% Entity_Manager copies registered functions into Entity on allocation
    Entity_Manager ..> Entity : allocate, release, sanitize_entity_functions

    %% Serialization uses Serialization_Request and PLATFORM_File_System_Context
    Entity ..> Serialization_Request : serialize / deserialize

    %% Entity_Manager uses hashing for UUID lookup
    Entity_Manager ..> Serialization_Header : UUID-based lookup via dehash
