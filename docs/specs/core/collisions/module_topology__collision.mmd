        +Collision_Node *p_collision_node
    }

    class Global_Space_Manager {
        +Global_Space global_spaces[QUANTITY_OF__GLOBAL_SPACE]
        +f_Global_Space__Dispose_Handler f_global_space__dispose_handler
    }

    class Hitbox_Manager_Type {
        <<enumeration>>
        Hitbox_Manager_Type__Default
        Hitbox_Manager_Type__AABB
        Hitbox_Manager_Type__AAABBB
        Hitbox_Manager_Type__Unknown
    }

    %% Ownership: Game owns Hitbox_Context and World
    Game *-- Hitbox_Context : owns
    Game *-- World : owns via pM_world

    %% Ownership: World owns Collision_Node_Pool and Global_Space_Manager
    World *-- Collision_Node_Pool : owns
    World *-- Global_Space_Manager : owns

    %% Hitbox_Context owns instances and tables
    Hitbox_Context *-- "0..8" Hitbox_Manager_Instance : owns pool
    Hitbox_Context *-- Hitbox_Manager_Instance__Invocation_Table : owns per type
    Hitbox_Context *-- Hitbox_Manager_Registration_Record : owns per type

    %% Hitbox_Manager_Instance holds opaque pointer to concrete manager
    Hitbox_Manager_Instance --> Hitbox_AABB_Manager : pVM_hitbox_manager (opaque)
    Hitbox_Manager_Instance --> Hitbox_Manager_Type : type_of__hitbox_manager

    %% Hitbox_AABB_Manager implements Hitbox_Manager_Intrinsic
    Hitbox_AABB_Manager ..|> Hitbox_Manager_Intrinsic : union cast
    Hitbox_AABB_Manager *-- "0..256" Hitbox_AABB : pM_pool_of__hitboxes

    %% Hitbox_AABB uses Hitbox_Flags__u8
    Hitbox_AABB *-- Hitbox_Flags__u8 : hitbox_aabb_flags__u8

    %% Collision_Node_Pool owns nodes and entries
    Collision_Node_Pool *-- "N" Collision_Node : collision_nodes array
    Collision_Node_Pool *-- "256" Collision_Node_Entry : collision_node_entries array

    %% Collision_Node has linked list of entries
    Collision_Node --> "0..*" Collision_Node_Entry : linked list tail
    Collision_Node_Entry --> Collision_Node_Entry : p_previous_entry

    %% Collision_Node_Entry references Hitbox_AABB by UUID
    Collision_Node_Entry ..> Hitbox_AABB : uuid_of__hitbox__u32 references

    %% Global_Space references Collision_Node
    Global_Space --> Collision_Node : p_collision_node
    Global_Space_Manager *-- "N" Global_Space : global_spaces array
