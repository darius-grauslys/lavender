    class Makefile_tests {
        <<build system>>
        +CFLAGS -Wall -O2
        +SOURCE_TEST_CORE
        +INCLUDE_TEST_CORE
        +SOURCE_TEST_PLATFORM
        +INCLUDE_TEST_PLATFORM
        +SOURCE_TEST_GAME
        +INCLUDE_TEST_GAME
        +CORE_OMIT main.c
        +OFILES
        +OUTPUT
    }

    %% Entry point wires root suite and invokes runner
    main_c --> MAIN_TEST_SUITE__CORE_ANCIENTS_GAME_c : calls include_test_suite__CORE_ANCIENTS_GAME
    main_c --> TestRunner : passes MunitSuite to munit_suite_main

    %% TestRunner uses MunitSuite tree
    TestRunner *-- MunitSuite : runs root suite
    TestRunner ..> MunitResult : returns per test

    %% MunitSuite contains tests and child suites
    MunitSuite *-- "0..*" MunitTest : tests array
    MunitSuite *-- "0..*" MunitSuite : suites array

    %% test_util.h macros produce MunitSuite and MunitTest structs
    test_util_h ..> MunitSuite : DEFINE_SUITE / DEFINE_SUITE_WITH__SUB_SUITES produce
    test_util_h ..> MunitTest : INCLUDE_TEST* macros produce

    %% Root header aggregates all sub-suite declarations
    MAIN_TEST_SUITE__CORE_ANCIENTS_GAME_h --> "7" ModuleSuiteHeader : includes module headers
    MAIN_TEST_SUITE__CORE_ANCIENTS_GAME_h --> "18" DirectorySuite : includes directory MAIN_TEST_SUITE headers

    %% Root source wires 25 sub-suites + NULL
    MAIN_TEST_SUITE__CORE_ANCIENTS_GAME_c --> "7" ModuleSuiteSource : INCLUDE_SUITE(module)
    MAIN_TEST_SUITE__CORE_ANCIENTS_GAME_c --> "18" DirectorySuite : INCLUDE_SUITE(CORE_DIR)

    %% Directory suites aggregate module suites and nested directory suites
    DirectorySuite *-- "0..*" ModuleSuiteSource : sub_suites
    DirectorySuite *-- "0..*" DirectorySuite : sub_suites (nested)

    %% Module suite source includes original .c and defines tests
    ModuleSuiteSource ..> MunitSuite : DEFINE_SUITE populates
    ModuleSuiteSource ..> MunitTest : TEST_FUNCTION registered via INCLUDE_TEST__STATELESS
    ModuleSuiteHeader ..> ModuleSuiteSource : declares include_test_suite__module

    %% Code generation scripts produce the suite hierarchy
    update_sh --> update_recursive_sh : delegates per directory tree
    update_sh ..> MAIN_TEST_SUITE__CORE_ANCIENTS_GAME_c : generates root source
    update_sh ..> MAIN_TEST_SUITE__CORE_ANCIENTS_GAME_h : generates root header
    update_sh ..> main_c : generates entry point
    update_recursive_sh ..> DirectorySuite : generates directory suites
    update_recursive_sh ..> ModuleSuiteHeader : generates stub headers if missing
    update_recursive_sh ..> ModuleSuiteSource : generates stub sources if missing

    %% Platform stubs provide linkable symbols
    platform_defines_h ..> PLATFORM_c : constants consumed by stub implementations
    PLATFORM_c ..> Makefile_tests : linked into test binary when no platform

    %% Makefile orchestrates compilation and linking
    Makefile_tests ..> main_c : compiles
    Makefile_tests ..> MAIN_TEST_SUITE__CORE_ANCIENTS_GAME_c : compiles
    Makefile_tests ..> DirectorySuite : compiles all generated sources
    Makefile_tests ..> ModuleSuiteSource : compiles all test sources
    Makefile_tests ..> PLATFORM_c : compiles when no real platform
    Makefile_tests ..> TestRunner : links into final binary
