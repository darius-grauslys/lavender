    %% Ownership: Game owns Gfx_Context
    Game *-- Gfx_Context : owns

    %% Gfx_Context owns UI_Context, UI_Tile_Map_Manager
    Gfx_Context *-- UI_Context : owns
    Gfx_Context *-- UI_Tile_Map_Manager : owns

    %% UI_Context owns UI_Manager pool and UI_Window_Record registry
    UI_Context *-- "0..8" UI_Manager : ui_managers pool
    UI_Context *-- "N" UI_Window_Record : ui_window_record registry

    %% UI_Manager owns UI_Element pool
    UI_Manager *-- "0..N" UI_Element : pM_ui_element_pool
    UI_Manager *-- UI_Manager_Flags__u8 : ui_manager_flags__u8
    UI_Manager --> UI_Element : p_ui_element__focused

    %% UI_Element uses UI_Element_Kind discriminator
    UI_Element *-- UI_Flags__u16 : ui_flags
    UI_Element --> UI_Element_Kind : the_kind_of_ui_element__this_is

    %% UI_Element tree structure (self-referential)
    UI_Element --> UI_Element : p_parent
    UI_Element --> UI_Element : p_child
    UI_Element --> UI_Element : p_next

    %% UI_Element contains UI_Tile_Span for tile-based rendering
    UI_Element *-- UI_Tile_Span : ui_tile_span

    %% UI_Element union: Button variant
    UI_Element *-- UI_Button_Flags__u8 : ui_button_flags (union, Button)

    %% UI_Element union: Slider variant
    UI_Element --> "Vector__3i32" UI_Element : slider__spanning_length__3i32 (union, Slider)

    %% UI_Element union: Text/Text_Box variant
    UI_Element --> Typer : typer (union, Text/Text_Box)

    %% UI_Element union: Window variant
    UI_Element --> Graphics_Window : p_ui_window__graphics_window (union, Window)

    %% UI_Tile_Span contains UI_Tile instances
    UI_Tile_Span *-- "9" UI_Tile : corners + edges + fill

    %% UI_Tile_Map__Wrapper references UI_Tile_Raw data
    UI_Tile_Map__Wrapper --> UI_Tile_Map_Size : catagory_size_of__ui_tile_map

    %% UI_Tile_Map_Manager pools tile maps of each size
    UI_Tile_Map_Manager *-- UI_Tile_Map__Wrapper : allocates wrappers

    %% Graphics_Window contains a UI_Tile_Map__Wrapper
    Graphics_Window *-- UI_Tile_Map__Wrapper : ui_tile_map__wrapper

    %% UI_Element spatial data is stored externally in Hitbox_AABB
    UI_Element ..> Hitbox_AABB : UUID-based lookup
    UI_Element ..> Hitbox_AABB_Manager : get_p_hitbox_aabb_of__ui_element

    %% UI_Element rendering modes
    UI_Element ..> Sprite : sprite mode (optional)
    UI_Element ..> Font : text rendering (Text/Text_Box)

    %% UI_Window_Record drives window lifecycle
    UI_Window_Record ..> UI_Manager : load callback populates
    UI_Window_Record ..> Graphics_Window : load callback targets

    %% Platform compose reads tile map
    Graphics_Window ..> UI_Tile_Map__Wrapper : f_PLATFORM_compose_gfx_window reads
