}

##############################################################################
# Main logic
##############################################################################

LEAF_NAME="${PARTS[-1]}"
DIR_PARTS=("${PARTS[@]:0:${#PARTS[@]}-1}")

# If there are no directory parts, the leaf is directly under implemented/
# e.g. "my_action.h" => just a leaf with no intermediate union headers
# But typically there's at least one directory level.

# Step 1: Create directories and intermediate union headers
CURRENT_DIR="$BASE_DIR"
ACCUMULATED_PREFIX=""

# Track the root union header for step 5
ROOT_UNION_HEADER_NAME=""
ROOT_UNION_DIR_PATH=""
ROOT_UNION_STRUCT_NAME=""

for (( i=0; i<${#DIR_PARTS[@]}; i++ )); do
    COMPONENT="${DIR_PARTS[$i]}"
    CURRENT_DIR="${CURRENT_DIR}/${COMPONENT}"

    if [ -z "$ACCUMULATED_PREFIX" ]; then
        ACCUMULATED_PREFIX="${COMPONENT}"
    else
        ACCUMULATED_PREFIX="${ACCUMULATED_PREFIX}__${COMPONENT}"
    fi

    # Create directory if needed
    mkdir -p "$CURRENT_DIR"

    # Union header filename: ga_types__<accumulated_prefix>.h
    UNION_HEADER_NAME="ga_types__${ACCUMULATED_PREFIX}.h"
    UNION_HEADER_PATH="${CURRENT_DIR}/${UNION_HEADER_NAME}"

    UPPER_PREFIX="$(to_upper "$ACCUMULATED_PREFIX")"
    GUARD_NAME="GA_TYPES__${UPPER_PREFIX}_H"
    STRUCT_NAME="$(to_struct_name "$ACCUMULATED_PREFIX" "union")"
    INJECTION_TAG="${UPPER_PREFIX}"

    # Track root for step 5
    if [ "$i" -eq 0 ]; then
        ROOT_UNION_HEADER_NAME="$UNION_HEADER_NAME"
        ROOT_UNION_DIR_PATH="${DIR_PARTS[0]}"
    fi

    if [ ! -f "$UNION_HEADER_PATH" ]; then
        log_verbose "Generating union header: $UNION_HEADER_PATH"
        generate_union_header "$UNION_HEADER_PATH" "$ACCUMULATED_PREFIX" \
            "$GUARD_NAME" "$STRUCT_NAME" "$INJECTION_TAG"
    fi

    # Generate accessors for union header fields (if any)
    if [ -f "$UNION_HEADER_PATH" ]; then
        UNION_FIELDS="$(parse_fields "$UNION_HEADER_PATH")"
        if [ -n "$UNION_FIELDS" ]; then
            log_verbose "Generating accessors for union fields in ${UNION_HEADER_PATH}"
            while IFS= read -r field_line; do
                FIELD_TYPE="$(echo "$field_line" | cut -d'|' -f1)"
                FIELD_NAME="$(echo "$field_line" | cut -d'|' -f2)"
                if [ -n "$FIELD_TYPE" ] && [ -n "$FIELD_NAME" ]; then
                    generate_accessors_for_field "$UNION_HEADER_PATH" \
                        "$STRUCT_NAME" "$FIELD_TYPE" "$FIELD_NAME" "union"
                fi
            done <<< "$UNION_FIELDS"
        fi
    fi

    # If this is not the first level, the parent union header needs to include this one
    if [ "$i" -gt 0 ]; then
        PARENT_PREFIX="$(build_prefix $i "${DIR_PARTS[@]}")"
        PARENT_DIR="$(dirname "$CURRENT_DIR")"
        PARENT_HEADER_NAME="ga_types__${PARENT_PREFIX}.h"
        PARENT_HEADER_PATH="${PARENT_DIR}/${PARENT_HEADER_NAME}"

        # Build the actual relative include path based on directory structure
        INCLUDE_DIR_PATH=""
        for (( j=0; j<=i; j++ )); do
            if [ -z "$INCLUDE_DIR_PATH" ]; then
                INCLUDE_DIR_PATH="${DIR_PARTS[$j]}"
            else
                INCLUDE_DIR_PATH="${INCLUDE_DIR_PATH}/${DIR_PARTS[$j]}"
            fi
        done
        INCLUDE_LINE="#include \"game_action/types/implemented/${INCLUDE_DIR_PATH}/${UNION_HEADER_NAME}\""

        if [ -f "$PARENT_HEADER_PATH" ]; then
            log_verbose "Ensuring include of ${UNION_HEADER_NAME} in ${PARENT_HEADER_PATH}"
            ensure_include_in_gen_region "$PARENT_HEADER_PATH" "$INCLUDE_LINE" || true
        fi
    fi
done

# Step 2: Create the leaf header
if [ -z "$ACCUMULATED_PREFIX" ]; then
    LEAF_PREFIX="${LEAF_NAME}"
else
    LEAF_PREFIX="${ACCUMULATED_PREFIX}__${LEAF_NAME}"
fi

LEAF_HEADER_NAME="ga_type__${LEAF_PREFIX}.h"

if [ ${#DIR_PARTS[@]} -gt 0 ]; then
    LEAF_DIR="$CURRENT_DIR"
else
    LEAF_DIR="$BASE_DIR"
    mkdir -p "$LEAF_DIR"
fi

LEAF_HEADER_PATH="${LEAF_DIR}/${LEAF_HEADER_NAME}"

UPPER_LEAF_PREFIX="$(to_upper "$LEAF_PREFIX")"
LEAF_GUARD="GA_TYPE__${UPPER_LEAF_PREFIX}_H"
LEAF_IMPL_GUARD="GA_TYPE__${UPPER_LEAF_PREFIX}_IMPL_H"
LEAF_STRUCT_NAME="$(to_struct_name "$LEAF_PREFIX" "type")"

if [ ! -f "$LEAF_HEADER_PATH" ]; then
    log_verbose "Generating leaf header: $LEAF_HEADER_PATH"
    generate_leaf_header "$LEAF_HEADER_PATH" "$LEAF_PREFIX" \
        "$LEAF_GUARD" "$LEAF_STRUCT_NAME" "$LEAF_IMPL_GUARD"
fi

# Step 3: Ensure the parent union header includes the leaf
if [ ${#DIR_PARTS[@]} -gt 0 ]; then
    PARENT_UNION_PREFIX="$ACCUMULATED_PREFIX"
    PARENT_UNION_HEADER_NAME="ga_types__${PARENT_UNION_PREFIX}.h"
    PARENT_UNION_HEADER_PATH="${LEAF_DIR}/${PARENT_UNION_HEADER_NAME}"

    # Build include path
    INCLUDE_DIR_PATH=""
    for (( j=0; j<${#DIR_PARTS[@]}; j++ )); do
        if [ -z "$INCLUDE_DIR_PATH" ]; then
            INCLUDE_DIR_PATH="${DIR_PARTS[$j]}"
        else
            INCLUDE_DIR_PATH="${INCLUDE_DIR_PATH}/${DIR_PARTS[$j]}"
        fi
    done
    LEAF_INCLUDE_LINE="#include \"game_action/types/implemented/${INCLUDE_DIR_PATH}/${LEAF_HEADER_NAME}\""

    if [ -f "$PARENT_UNION_HEADER_PATH" ]; then
        log_verbose "Ensuring include of ${LEAF_HEADER_NAME} in ${PARENT_UNION_HEADER_PATH}"
        ensure_include_in_gen_region "$PARENT_UNION_HEADER_PATH" "$LEAF_INCLUDE_LINE" || true
    fi
fi

# Step 4: Accessor generation for the leaf header
# Parse fields and generate any missing accessors
if [ -f "$LEAF_HEADER_PATH" ]; then
    FIELDS="$(parse_fields "$LEAF_HEADER_PATH")"
    if [ -n "$FIELDS" ]; then
        log_verbose "Generating accessors for fields in ${LEAF_HEADER_PATH}"
        while IFS= read -r field_line; do
            FIELD_TYPE="$(echo "$field_line" | cut -d'|' -f1)"
            FIELD_NAME="$(echo "$field_line" | cut -d'|' -f2)"
            if [ -n "$FIELD_TYPE" ] && [ -n "$FIELD_NAME" ]; then
                generate_accessors_for_field "$LEAF_HEADER_PATH" \
                    "$LEAF_STRUCT_NAME" "$FIELD_TYPE" "$FIELD_NAME" "leaf"
            fi
        done <<< "$FIELDS"
    else
        log_verbose "No fields found in ${LEAF_HEADER_PATH}. Add fields between FIELDS-BEGIN and FIELDS-END, then re-run."
    fi
fi

# Step 5: Ensure root union header is included in ga_types__implemented.h
IMPLEMENTED_HEADER="${BASE_DIR}/ga_types__implemented.h"
if [ -n "$ROOT_UNION_HEADER_NAME" ] && [ -f "$IMPLEMENTED_HEADER" ]; then
    ROOT_INCLUDE_LINE="#include \"game_action/types/implemented/${ROOT_UNION_DIR_PATH}/${ROOT_UNION_HEADER_NAME}\""
    log_verbose "Ensuring include of ${ROOT_UNION_HEADER_NAME} in ${IMPLEMENTED_HEADER}"
    ensure_include_in_gen_region "$IMPLEMENTED_HEADER" "$ROOT_INCLUDE_LINE" || true
elif [ -n "$ROOT_UNION_HEADER_NAME" ] && [ ! -f "$IMPLEMENTED_HEADER" ]; then
    log_verbose "Warning: ${IMPLEMENTED_HEADER} not found. Cannot add root include."
elif [ ${#DIR_PARTS[@]} -eq 0 ]; then
    # Leaf directly under implemented/ — include the leaf itself
    LEAF_INCLUDE_FOR_ROOT="#include \"game_action/types/implemented/${LEAF_HEADER_NAME}\""
    if [ -f "$IMPLEMENTED_HEADER" ]; then
        log_verbose "Ensuring include of ${LEAF_HEADER_NAME} in ${IMPLEMENTED_HEADER}"
        ensure_include_in_gen_region "$IMPLEMENTED_HEADER" "$LEAF_INCLUDE_FOR_ROOT" || true
    else
        log_verbose "Warning: ${IMPLEMENTED_HEADER} not found. Cannot add root include."
    fi
fi

# Step 6: Generate game_action .h and .c files under ./include and ./source
FUNC_SUFFIX="${LEAF_PREFIX}"

# Build subdirectory path for include/source
GA_SUBDIR_PATH=""
for (( j=0; j<${#DIR_PARTS[@]}; j++ )); do
    if [ -z "$GA_SUBDIR_PATH" ]; then
        GA_SUBDIR_PATH="${DIR_PARTS[$j]}"
    else
        GA_SUBDIR_PATH="${GA_SUBDIR_PATH}/${DIR_PARTS[$j]}"
    fi
done

# Header file path
GA_INCLUDE_DIR="./include/game_action/implemented"
if [ -n "$GA_SUBDIR_PATH" ]; then
    GA_INCLUDE_DIR="${GA_INCLUDE_DIR}/${GA_SUBDIR_PATH}"
fi
mkdir -p "$GA_INCLUDE_DIR"

GA_HEADER_FILENAME="game_action__${LEAF_PREFIX}.h"
GA_HEADER_PATH="${GA_INCLUDE_DIR}/${GA_HEADER_FILENAME}"

# Source file path
GA_SOURCE_DIR="./source/game_action/implemented"
if [ -n "$GA_SUBDIR_PATH" ]; then
    GA_SOURCE_DIR="${GA_SOURCE_DIR}/${GA_SUBDIR_PATH}"
fi
mkdir -p "$GA_SOURCE_DIR"

GA_SOURCE_FILENAME="game_action__${LEAF_PREFIX}.c"
GA_SOURCE_PATH="${GA_SOURCE_DIR}/${GA_SOURCE_FILENAME}"

# Build guard name for the .h
GA_HEADER_GUARD="GAME_ACTION__$(to_upper "$LEAF_PREFIX")_H"

# Build the type include path (relative from include/)
TYPE_INCLUDE_REL_PATH="game_action/types/implemented"
if [ -n "$GA_SUBDIR_PATH" ]; then
    TYPE_INCLUDE_REL_PATH="${TYPE_INCLUDE_REL_PATH}/${GA_SUBDIR_PATH}"
fi
TYPE_INCLUDE_REL_PATH="${TYPE_INCLUDE_REL_PATH}/${LEAF_HEADER_NAME}"

# Build union include paths (all intermediate union headers)
UNION_INCLUDE_PATHS=""
UNION_ACC_PREFIX=""
UNION_DIR_ACC=""
for (( i=0; i<${#DIR_PARTS[@]}; i++ )); do
    if [ -z "$UNION_ACC_PREFIX" ]; then
        UNION_ACC_PREFIX="${DIR_PARTS[$i]}"
        UNION_DIR_ACC="${DIR_PARTS[$i]}"
    else
        UNION_ACC_PREFIX="${UNION_ACC_PREFIX}__${DIR_PARTS[$i]}"
        UNION_DIR_ACC="${UNION_DIR_ACC}/${DIR_PARTS[$i]}"
    fi
    UNION_HDR="game_action/types/implemented/${UNION_DIR_ACC}/ga_types__${UNION_ACC_PREFIX}.h"
    if [ -z "$UNION_INCLUDE_PATHS" ]; then
        UNION_INCLUDE_PATHS="${UNION_HDR}"
    else
        UNION_INCLUDE_PATHS="${UNION_INCLUDE_PATHS}
${UNION_HDR}"
    fi
done

# Header include path for the .c file
GA_HEADER_INCLUDE_PATH="game_action/implemented"
if [ -n "$GA_SUBDIR_PATH" ]; then
    GA_HEADER_INCLUDE_PATH="${GA_HEADER_INCLUDE_PATH}/${GA_SUBDIR_PATH}"
fi
GA_HEADER_INCLUDE_PATH="${GA_HEADER_INCLUDE_PATH}/${GA_HEADER_FILENAME}"

# Generate .h if missing
if [ ! -f "$GA_HEADER_PATH" ]; then
    log_verbose "Generating game action header: $GA_HEADER_PATH"
    generate_game_action_header \
        "$GA_HEADER_PATH" \
        "$LEAF_PREFIX" \
        "$LEAF_STRUCT_NAME" \
        "$GA_HEADER_GUARD" \
        "$FUNC_SUFFIX" \
        "$TYPE_INCLUDE_REL_PATH" \
        "$UNION_INCLUDE_PATHS" \
        "$LEAF_HEADER_PATH"
else
    log_verbose "Game action header already exists: $GA_HEADER_PATH"
fi

# Generate .c if missing
if [ ! -f "$GA_SOURCE_PATH" ]; then
    log_verbose "Generating game action source: $GA_SOURCE_PATH"
    generate_game_action_source \
        "$GA_SOURCE_PATH" \
        "$GA_HEADER_INCLUDE_PATH" \
        "$FUNC_SUFFIX" \
        "$LEAF_STRUCT_NAME" \
        "$LEAF_HEADER_PATH"
else
    log_verbose "Game action source already exists: $GA_SOURCE_PATH"
fi

# Reminder about registrar
if [ -f "./source/game_action/implemented/game_action_registrar.c" ]; then
    log_verbose "Reminder: Add registration calls for game_action__${FUNC_SUFFIX} to game_action_registrar.c"
fi

# Output the leaf header path relative to pwd on success
echo "${LEAF_HEADER_PATH}"
