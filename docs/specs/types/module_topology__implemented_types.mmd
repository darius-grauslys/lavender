    %% -------------------------------------------------------
    %% Injection relationships: enum templates -> defines_weak.h
    %% -------------------------------------------------------

    tile_kind_h ..> defines_weak_h : injected via DEFINE_TILE_KIND
    entity_kind_h ..> defines_weak_h : injected via DEFINE_ENTITY_KIND
    item_kind_h ..> defines_weak_h : injected via DEFINE_ITEM_KIND
    scene_kind_h ..> defines_weak_h : injected via DEFINE_SCENE_KIND
    sprite_kind_h ..> defines_weak_h : injected via DEFINE_SPRITE_KIND
    sprite_animation_kind_h ..> defines_weak_h : injected via DEFINE_SPRITE_ANIMATION_KIND
    sprite_animation_group_kind_h ..> defines_weak_h : injected via DEFINE_SPRITE_ANIMATION_GROUP_KIND
    audio_effect_kind_h ..> defines_weak_h : injected via DEFINE_AUDIO_EFFECT_KIND
    audio_stream_kind_h ..> defines_weak_h : injected via DEFINE_AUDIO_STREAM_KIND
    ui_element_kind_h ..> defines_weak_h : injected via DEFINE_UI_ELEMENT_KIND
    ui_tile_kind_h ..> defines_weak_h : injected via DEFINE_UI_TILE_KIND
    ui_sprite_kind_h ..> defines_weak_h : injected via DEFINE_UI_SPRITE_KIND
    graphics_window_kind_h ..> defines_weak_h : injected via DEFINE_GRAPHICS_WINDOW_KIND
    game_action_kind_h ..> defines_weak_h : injected via DEFINE_GAME_ACTION_KIND
    chunk_generator_kind_h ..> defines_weak_h : injected via DEFINE_CHUNK_GENERATOR_KIND
    hitbox_kind_h ..> defines_weak_h : injected via DEFINE_HITBOX_KIND
    hitbox_manager_type_h ..> defines_weak_h : injected via DEFINE_HITBOX_MANAGER_TYPE

    %% -------------------------------------------------------
    %% Injection relationships: struct/constant templates -> defines.h
    %% -------------------------------------------------------

    tile_h ..> defines_h : injected via DEFINE_TILE
    entity_data_h ..> defines_h : injected via DEFINE_ENTITY_DATA
    entity_functions_h ..> defines_h : injected via DEFINE_ENTITY_FUNCTIONS
    item_data_h ..> defines_h : injected via DEFINE_ITEM_DATA
    ui_element_data_h ..> defines_h : injected via DEFINE_UI_ELEMENT_DATA
    tile_logic_table_data_h ..> defines_h : injected via DEFINE_TILE_LOGIC_TABLE_DATA
    tile_logic_table_list_h ..> defines_h : injected via DEFINE_TILE_LOGIC_TABLE_LIST

    %% -------------------------------------------------------
    %% defines.h depends on defines_weak.h
    %% -------------------------------------------------------

    defines_h --> defines_weak_h : includes (weak types available)

    %% -------------------------------------------------------
    %% Cross-template type dependencies
    %% -------------------------------------------------------

    tile_h --> tile_kind_h : uses Tile_Kind
    entity_data_h --> entity_kind_h : uses Entity_Kind
    tile_logic_table_data_h --> tile_kind_h : sized by Tile_Kind__Unknown
    game_action_kind_h --> hitbox_kind_h : Hitbox__End delimiter

    %% -------------------------------------------------------
    %% Runtime consumer relationships (array sizing)
    %% -------------------------------------------------------

    class Entity_Manager {
        <<runtime consumer>>
        +entity_functions[Entity_Kind__Unknown]
    }

    class Scene_Manager {
        <<runtime consumer>>
        +scenes[Scene_Kind__Unknown]
    }

    class Sprite_Context {
        <<runtime consumer>>
        +sprite_animations[Sprite_Animation_Kind__Unknown]
        +sprite_animation_groups[Sprite_Animation_Group_Kind__Unknown]
    }

    class Tile_Logic_Table {
        <<runtime consumer>>
        +tile_logic_table_data : Tile_Logic_Table_Data
    }

    class Chunk_Generator_Table {
        <<runtime consumer>>
        +M_process__chunk_generators[Chunk_Generator_Kind__Unknown]
    }

    class Game_Action_Logic_Table {
        <<runtime consumer>>
        +game_action_logic_entries[Game_Action_Kind__Unknown]
    }

    class UI_Context {
        <<runtime consumer>>
        +ui_window_record[Graphics_Window_Kind__Unknown]
    }

    class Hitbox_Context_Consumer {
        <<runtime consumer>>
        +hitbox_manager_instance__invocation_table[Hitbox_Manager_Type__Unknown]
        +hitbox_manager_registration_records[Hitbox_Manager_Type__Unknown]
    }

    entity_kind_h ..> Entity_Manager : sizes entity_functions[]
    entity_functions_h ..> Entity_Manager : element type
    scene_kind_h ..> Scene_Manager : sizes scenes[]
    sprite_animation_kind_h ..> Sprite_Context : sizes sprite_animations[]
    sprite_animation_group_kind_h ..> Sprite_Context : sizes sprite_animation_groups[]
    tile_kind_h ..> Tile_Logic_Table : sizes via Tile_Logic_Table_Data
    tile_logic_table_data_h ..> Tile_Logic_Table : embedded struct
    chunk_generator_kind_h ..> Chunk_Generator_Table : sizes M_process__chunk_generators[]
    game_action_kind_h ..> Game_Action_Logic_Table : sizes game_action_logic_entries[]
    graphics_window_kind_h ..> UI_Context : sizes ui_window_record[]
    hitbox_manager_type_h ..> Hitbox_Context_Consumer : sizes invocation/registration tables
