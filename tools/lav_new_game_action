#!/bin/bash
#
# lav_new_game_action
#
# Deterministically generated script for creating game action type headers.
# This script creates the directory structure and header files for a new
# game action type under ./include/game_action/types/implemented/
#
# Usage: lav_new_game_action <relative/path/to/leaf.h>
#
# Example: lav_new_game_action collisions/aabb/update__pos_vec_i32.h
#   Creates:
#     include/game_action/types/implemented/collisions/ga_types__collisions.h
#     include/game_action/types/implemented/collisions/aabb/ga_types__collisions__aabb.h
#     include/game_action/types/implemented/collisions/aabb/ga_type__collisions__aabb__update__pos_vec_i32.h
#

set -e

##############################################################################
# Validation
##############################################################################

if [ "$#" -ne 1 ]; then
    echo "Usage: $0 <relative/path/to/leaf.h>"
    echo "Example: $0 collisions/aabb/update__pos_vec_i32.h"
    exit 1
fi

REL_PATH="$1"

if [[ "$REL_PATH" != *.h ]]; then
    echo "Error: path must end with .h"
    exit 1
fi

# Strip the .h suffix for processing
REL_PATH_NO_EXT="${REL_PATH%.h}"

# Split path into components
IFS='/' read -ra PARTS <<< "$REL_PATH_NO_EXT"

if [ "${#PARTS[@]}" -lt 1 ]; then
    echo "Error: path must have at least one component."
    exit 1
fi

BASE_DIR="./include/game_action/types/implemented"

##############################################################################
# Helper: build the accumulated name prefix from path components
#   e.g. components=(collisions aabb) => collisions__aabb
##############################################################################
function build_prefix() {
    local count=$1
    shift
    local components=("$@")
    local result=""
    for (( i=0; i<count; i++ )); do
        if [ -z "$result" ]; then
            result="${components[$i]}"
        else
            result="${result}__${components[$i]}"
        fi
    done
    echo "$result"
}

##############################################################################
# Helper: convert a name like "collisions__aabb" to upper case "COLLISIONS__AABB"
##############################################################################
function to_upper() {
    echo "$1" | tr '[:lower:]' '[:upper:]'
}

##############################################################################
# Helper: convert a prefix like "collisions__aabb" to a struct-style name
#   "GA_Collisions__AABB" — we capitalize each segment after splitting on __
#   Actually looking at the codebase:
#     collisions => GA_Collisions
#     aabb => GA_AABB
#     tcp__connect_begin => GA_TCP_Connect__Begin
#   The convention is: each path component becomes a PascalCase/Upper segment.
#   We'll do: split on __, capitalize first letter of each _ separated word.
##############################################################################
function to_struct_name() {
    local prefix="$1"
    local kind="$2"  # "union" or "type"
    # Split on __ (double underscore) to get path-level segments
    local IFS_OLD="$IFS"
    local result="GA"
    # We split the prefix by __ to get the path-level segments
    # Then each segment's internal _ separated words get capitalized
    local segments=()
    local tmp="$prefix"
    while [[ "$tmp" == *"__"* ]]; do
        local seg="${tmp%%__*}"
        segments+=("$seg")
        tmp="${tmp#*__}"
    done
    segments+=("$tmp")

    for seg in "${segments[@]}"; do
        # Split segment by single _ and capitalize each word
        local words
        IFS='_' read -ra words <<< "$seg"
        local capitalized=""
        for word in "${words[@]}"; do
            if [ -z "$word" ]; then
                continue
            fi
            # Check if the word is all-caps-worthy (like "aabb", "tcp", "ip")
            # Heuristic: if 4 chars or fewer and looks like an acronym, uppercase all
            local len=${#word}
            if [ "$len" -le 4 ]; then
                capitalized="${capitalized}_$(to_upper "$word")"
            else
                capitalized="${capitalized}_$(echo "${word:0:1}" | tr '[:lower:]' '[:upper:]')${word:1}"
            fi
        done
        # Remove leading _
        capitalized="${capitalized#_}"
        result="${result}_${capitalized}"
    done

    IFS="$IFS_OLD"
    echo "$result"
}

##############################################################################
# Helper: generate a union (intermediate) header file
#   These are like ga_types__collisions.h or ga_types__aabb.h
##############################################################################
function generate_union_header() {
    local filepath="$1"
    local prefix="$2"          # e.g. "collisions" or "collisions__aabb"
    local guard_name="$3"      # e.g. "GA_TYPES__COLLISIONS_H"
    local struct_name="$4"     # e.g. "GA_Collisions"
    local injection_tag="$5"   # e.g. "COLLISIONS" or "COLLISIONS__AABB"
    local impl_guard="${guard_name%_H}_IMPL_H"

    cat > "$filepath" << HEADER_EOF
/// This file is deterministically generated. Do not edit manually
/// outside of designated GEN-BEGIN / GEN-END regions.
#ifndef ${guard_name}
#define ${guard_name}
#define GA_TYPE_CONTEXT

#ifndef DEFINES_H
#include <defines.h>
#endif

#include <util/custom_type_macro.h>

LAV_UNION__BEGIN(${struct_name}){

#ifndef INJECTION_ACTIVE
#define INJECTION_ACTIVE
#define INJECTION_ACTIVE__${injection_tag}
#endif
    struct {
// FIELDS-BEGIN
// FIELDS-END
        union {
// GEN-BEGIN
// GEN-END
        };
    };

#ifdef INJECTION_ACTIVE__${injection_tag}
#undef INJECTION_ACTIVE__${injection_tag}
#undef INJECTION_ACTIVE
#endif

} ${struct_name};

#undef GA_TYPE_CONTEXT
#endif // Header guard

#ifndef INJECTION_ACTIVE
#ifndef ${impl_guard}
#define ${impl_guard}

// GEN-IMPL-BEGIN
// GEN-IMPL-END

#endif // Impl Header guard
#endif // INJECTION_ACTIVE
HEADER_EOF
}

##############################################################################
# Helper: generate a leaf (type) header file
#   These are like ga_type__tcp__connect_begin.h
##############################################################################
function generate_leaf_header() {
    local filepath="$1"
    local prefix="$2"          # e.g. "collisions__aabb__update__pos_vec_i32"
    local guard_name="$3"      # e.g. "GA_TYPE__COLLISIONS__AABB__UPDATE__POS_VEC_I32_H"
    local struct_name="$4"     # e.g. "GA_Collisions__AABB__Update__Pos_Vec_I32"
    local impl_guard="$5"      # e.g. "GA_TYPE__COLLISIONS__AABB__UPDATE__POS_VEC_I32_IMPL_H"

    cat > "$filepath" << HEADER_EOF
/// This file is deterministically generated. Do not edit manually
/// outside of designated GEN / FIELDS regions.
#ifndef ${guard_name}
#define ${guard_name}
#define GA_TYPE_CONTEXT

#ifndef DEFINES_H
#include <defines.h>
#endif

#include <util/custom_type_macro.h>

LAV_TYPE__BEGIN(${struct_name}){
// FIELDS-BEGIN
// FIELDS-END
} ${struct_name};

#undef GA_TYPE_CONTEXT
#endif // Header guard

#ifndef INJECTION_ACTIVE
#ifndef ${impl_guard}
#define ${impl_guard}

// GEN-IMPL-BEGIN
// GEN-IMPL-END

#endif // Impl Header guard
#endif // INJECTION_ACTIVE
HEADER_EOF
}

##############################################################################
# Helper: ensure an #include line exists between GEN-BEGIN and GEN-END
#   in an existing union header file. Returns 0 if added, 1 if already present.
##############################################################################
function ensure_include_in_gen_region() {
    local filepath="$1"
    local include_line="$2"

    # Check if the include already exists between GEN-BEGIN and GEN-END
    local in_region=0
    local found=0
    while IFS= read -r line; do
        if [[ "$line" == *"// GEN-BEGIN"* ]]; then
            in_region=1
            continue
        fi
        if [[ "$line" == *"// GEN-END"* ]]; then
            in_region=0
            continue
        fi
        if [ "$in_region" -eq 1 ]; then
            # Trim whitespace for comparison
            local trimmed
            trimmed="$(echo "$line" | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//')"
            if [ "$trimmed" = "$include_line" ]; then
                found=1
                break
            fi
        fi
    done < "$filepath"

    if [ "$found" -eq 1 ]; then
        return 1
    fi

    # Insert the include line before // GEN-END
    local escaped_include
    escaped_include="$(echo "$include_line" | sed 's/[&/\]/\\&/g')"
    sed -i "0,/\/\/ GEN-END/{s|// GEN-END|${escaped_include}\n// GEN-END|}" "$filepath"
    return 0
}

##############################################################################
# Helper: parse fields from a leaf header between FIELDS-BEGIN and FIELDS-END
#   Outputs lines of: TYPE NAME
##############################################################################
function parse_fields() {
    local filepath="$1"
    local in_region=0
    while IFS= read -r line; do
        if [[ "$line" == *"// FIELDS-BEGIN"* ]]; then
            in_region=1
            continue
        fi
        if [[ "$line" == *"// FIELDS-END"* ]]; then
            in_region=0
            continue
        fi
        if [ "$in_region" -eq 1 ]; then
            # Try to parse a field declaration: TYPE NAME;
            local trimmed
            trimmed="$(echo "$line" | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//')"
            # Skip empty lines and comments
            if [ -z "$trimmed" ] || [[ "$trimmed" == "//"* ]] || [[ "$trimmed" == "/*"* ]]; then
                continue
            fi
            # Remove trailing semicolon
            trimmed="${trimmed%;}"
            # Split into type and name — last word is the name, rest is type
            local field_name
            field_name="$(echo "$trimmed" | awk '{print $NF}')"
            local field_type
            field_type="$(echo "$trimmed" | awk '{$NF=""; print}' | sed 's/[[:space:]]*$//')"
            if [ -n "$field_name" ] && [ -n "$field_type" ]; then
                echo "${field_type}|${field_name}"
            fi
        fi
    done < "$filepath"
}

##############################################################################
# Helper: check if an accessor comment marker exists in GEN-IMPL region
##############################################################################
function accessor_exists_in_impl() {
    local filepath="$1"
    local accessor_marker="$2"  # e.g. "// ACCESSOR: field_name"

    local in_region=0
    while IFS= read -r line; do
        if [[ "$line" == *"// GEN-IMPL-BEGIN"* ]]; then
            in_region=1
            continue
        fi
        if [[ "$line" == *"// GEN-IMPL-END"* ]]; then
            in_region=0
            continue
        fi
        if [ "$in_region" -eq 1 ]; then
            local trimmed
            trimmed="$(echo "$line" | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//')"
            if [ "$trimmed" = "$accessor_marker" ]; then
                return 0
            fi
        fi
    done < "$filepath"
    return 1
}

##############################################################################
# Helper: generate accessor functions for a field and insert before GEN-IMPL-END
##############################################################################
function generate_accessors_for_field() {
    local filepath="$1"
    local struct_name="$2"
    local field_type="$3"
    local field_name="$4"
    local header_kind="$5"  # "union" or "leaf"

    local lower_struct
    lower_struct="$(echo "$struct_name" | tr '[:upper:]' '[:lower:]')"

    local accessor_block=""

    # Check if getter accessor exists
    if ! accessor_exists_in_impl "$filepath" "// ACCESSOR: ${field_name}"; then
        if [ "$header_kind" = "union" ]; then
            accessor_block="${accessor_block}
// ACCESSOR: ${field_name}
static inline
${field_type} get_${field_name}_from__${lower_struct}(
        Game_Action *p_game_action) {
    return p_game_action
        ->${struct_name}
        .${field_name}
        ;
}"
        else
            accessor_block="${accessor_block}
// ACCESSOR: ${field_name}
static inline
${field_type} get_${field_name}_from__${lower_struct}(
        Game_Action *p_game_action) {
    return (GET_P_GAME_ACTION_PAYLOAD_AS(p_game_action, ${struct_name}))
        .${field_name}
        ;
}"
        fi
    fi

    # Check if pointer accessor exists
    if ! accessor_exists_in_impl "$filepath" "// ACCESSOR: p_${field_name}"; then
        if [ "$header_kind" = "union" ]; then
            accessor_block="${accessor_block}

// ACCESSOR: p_${field_name}
static inline
${field_type} *get_p_${field_name}_from__${lower_struct}(
        Game_Action *p_game_action) {
    return &p_game_action
        ->${struct_name}
        .${field_name}
        ;
}"
        else
            accessor_block="${accessor_block}

// ACCESSOR: p_${field_name}
static inline
${field_type} *get_p_${field_name}_from__${lower_struct}(
        Game_Action *p_game_action) {
    return &(GET_P_GAME_ACTION_PAYLOAD_AS(p_game_action, ${struct_name}))
        .${field_name}
        ;
}"
        fi
    fi

    if [ -n "$accessor_block" ]; then
        # We need to insert before // GEN-IMPL-END
        # Write accessor block to a temp file to handle multiline sed
        local tmpfile
        tmpfile=$(mktemp)
        echo "$accessor_block" > "$tmpfile"

        # Use python for reliable multiline insertion since sed struggles
        python3 -c "
import sys
marker = '// GEN-IMPL-END'
with open('${filepath}', 'r') as f:
    content = f.read()
with open('${tmpfile}', 'r') as f:
    insertion = f.read()
# Insert before the first occurrence of GEN-IMPL-END
idx = content.find(marker)
if idx != -1:
    content = content[:idx] + insertion + '\n' + content[idx:]
with open('${filepath}', 'w') as f:
    f.write(content)
"
        rm -f "$tmpfile"
    fi
}

##############################################################################
# Main logic
##############################################################################

LEAF_NAME="${PARTS[-1]}"
DIR_PARTS=("${PARTS[@]:0:${#PARTS[@]}-1}")

# If there are no directory parts, the leaf is directly under implemented/
# e.g. "my_action.h" => just a leaf with no intermediate union headers
# But typically there's at least one directory level.

# Step 1: Create directories and intermediate union headers
CURRENT_DIR="$BASE_DIR"
ACCUMULATED_PREFIX=""

# Track the root union header for step 5
ROOT_UNION_HEADER_NAME=""
ROOT_UNION_DIR_PATH=""
ROOT_UNION_STRUCT_NAME=""

for (( i=0; i<${#DIR_PARTS[@]}; i++ )); do
    COMPONENT="${DIR_PARTS[$i]}"
    CURRENT_DIR="${CURRENT_DIR}/${COMPONENT}"

    if [ -z "$ACCUMULATED_PREFIX" ]; then
        ACCUMULATED_PREFIX="${COMPONENT}"
    else
        ACCUMULATED_PREFIX="${ACCUMULATED_PREFIX}__${COMPONENT}"
    fi

    # Create directory if needed
    mkdir -p "$CURRENT_DIR"

    # Union header filename: ga_types__<accumulated_prefix>.h
    UNION_HEADER_NAME="ga_types__${ACCUMULATED_PREFIX}.h"
    UNION_HEADER_PATH="${CURRENT_DIR}/${UNION_HEADER_NAME}"

    UPPER_PREFIX="$(to_upper "$ACCUMULATED_PREFIX")"
    GUARD_NAME="GA_TYPES__${UPPER_PREFIX}_H"
    STRUCT_NAME="$(to_struct_name "$ACCUMULATED_PREFIX" "union")"
    INJECTION_TAG="${UPPER_PREFIX}"

    # Track root for step 5
    if [ "$i" -eq 0 ]; then
        ROOT_UNION_HEADER_NAME="$UNION_HEADER_NAME"
        ROOT_UNION_DIR_PATH="${DIR_PARTS[0]}"
    fi

    if [ ! -f "$UNION_HEADER_PATH" ]; then
        echo "Generating union header: $UNION_HEADER_PATH"
        generate_union_header "$UNION_HEADER_PATH" "$ACCUMULATED_PREFIX" \
            "$GUARD_NAME" "$STRUCT_NAME" "$INJECTION_TAG"
    fi

    # Generate accessors for union header fields (if any)
    if [ -f "$UNION_HEADER_PATH" ]; then
        UNION_FIELDS="$(parse_fields "$UNION_HEADER_PATH")"
        if [ -n "$UNION_FIELDS" ]; then
            echo "Generating accessors for union fields in ${UNION_HEADER_PATH}"
            while IFS= read -r field_line; do
                FIELD_TYPE="$(echo "$field_line" | cut -d'|' -f1)"
                FIELD_NAME="$(echo "$field_line" | cut -d'|' -f2)"
                if [ -n "$FIELD_TYPE" ] && [ -n "$FIELD_NAME" ]; then
                    generate_accessors_for_field "$UNION_HEADER_PATH" \
                        "$STRUCT_NAME" "$FIELD_TYPE" "$FIELD_NAME" "union"
                fi
            done <<< "$UNION_FIELDS"
        fi
    fi

    # If this is not the first level, the parent union header needs to include this one
    if [ "$i" -gt 0 ]; then
        PARENT_PREFIX="$(build_prefix $i "${DIR_PARTS[@]}")"
        PARENT_DIR="$(dirname "$CURRENT_DIR")"
        PARENT_HEADER_NAME="ga_types__${PARENT_PREFIX}.h"
        PARENT_HEADER_PATH="${PARENT_DIR}/${PARENT_HEADER_NAME}"

        # Build the actual relative include path based on directory structure
        INCLUDE_DIR_PATH=""
        for (( j=0; j<=i; j++ )); do
            if [ -z "$INCLUDE_DIR_PATH" ]; then
                INCLUDE_DIR_PATH="${DIR_PARTS[$j]}"
            else
                INCLUDE_DIR_PATH="${INCLUDE_DIR_PATH}/${DIR_PARTS[$j]}"
            fi
        done
        INCLUDE_LINE="#include \"game_action/types/implemented/${INCLUDE_DIR_PATH}/${UNION_HEADER_NAME}\""

        if [ -f "$PARENT_HEADER_PATH" ]; then
            echo "Ensuring include of ${UNION_HEADER_NAME} in ${PARENT_HEADER_PATH}"
            ensure_include_in_gen_region "$PARENT_HEADER_PATH" "$INCLUDE_LINE" || true
        fi
    fi
done

# Step 2: Create the leaf header
if [ -z "$ACCUMULATED_PREFIX" ]; then
    LEAF_PREFIX="${LEAF_NAME}"
else
    LEAF_PREFIX="${ACCUMULATED_PREFIX}__${LEAF_NAME}"
fi

LEAF_HEADER_NAME="ga_type__${LEAF_PREFIX}.h"

if [ ${#DIR_PARTS[@]} -gt 0 ]; then
    LEAF_DIR="$CURRENT_DIR"
else
    LEAF_DIR="$BASE_DIR"
    mkdir -p "$LEAF_DIR"
fi

LEAF_HEADER_PATH="${LEAF_DIR}/${LEAF_HEADER_NAME}"

UPPER_LEAF_PREFIX="$(to_upper "$LEAF_PREFIX")"
LEAF_GUARD="GA_TYPE__${UPPER_LEAF_PREFIX}_H"
LEAF_IMPL_GUARD="GA_TYPE__${UPPER_LEAF_PREFIX}_IMPL_H"
LEAF_STRUCT_NAME="$(to_struct_name "$LEAF_PREFIX" "type")"

if [ ! -f "$LEAF_HEADER_PATH" ]; then
    echo "Generating leaf header: $LEAF_HEADER_PATH"
    generate_leaf_header "$LEAF_HEADER_PATH" "$LEAF_PREFIX" \
        "$LEAF_GUARD" "$LEAF_STRUCT_NAME" "$LEAF_IMPL_GUARD"
fi

# Step 3: Ensure the parent union header includes the leaf
if [ ${#DIR_PARTS[@]} -gt 0 ]; then
    PARENT_UNION_PREFIX="$ACCUMULATED_PREFIX"
    PARENT_UNION_HEADER_NAME="ga_types__${PARENT_UNION_PREFIX}.h"
    PARENT_UNION_HEADER_PATH="${LEAF_DIR}/${PARENT_UNION_HEADER_NAME}"

    # Build include path
    INCLUDE_DIR_PATH=""
    for (( j=0; j<${#DIR_PARTS[@]}; j++ )); do
        if [ -z "$INCLUDE_DIR_PATH" ]; then
            INCLUDE_DIR_PATH="${DIR_PARTS[$j]}"
        else
            INCLUDE_DIR_PATH="${INCLUDE_DIR_PATH}/${DIR_PARTS[$j]}"
        fi
    done
    LEAF_INCLUDE_LINE="#include \"game_action/types/implemented/${INCLUDE_DIR_PATH}/${LEAF_HEADER_NAME}\""

    if [ -f "$PARENT_UNION_HEADER_PATH" ]; then
        echo "Ensuring include of ${LEAF_HEADER_NAME} in ${PARENT_UNION_HEADER_PATH}"
        ensure_include_in_gen_region "$PARENT_UNION_HEADER_PATH" "$LEAF_INCLUDE_LINE" || true
    fi
fi

# Step 4: Accessor generation for the leaf header
# Parse fields and generate any missing accessors
if [ -f "$LEAF_HEADER_PATH" ]; then
    FIELDS="$(parse_fields "$LEAF_HEADER_PATH")"
    if [ -n "$FIELDS" ]; then
        echo "Generating accessors for fields in ${LEAF_HEADER_PATH}"
        while IFS= read -r field_line; do
            FIELD_TYPE="$(echo "$field_line" | cut -d'|' -f1)"
            FIELD_NAME="$(echo "$field_line" | cut -d'|' -f2)"
            if [ -n "$FIELD_TYPE" ] && [ -n "$FIELD_NAME" ]; then
                generate_accessors_for_field "$LEAF_HEADER_PATH" \
                    "$LEAF_STRUCT_NAME" "$FIELD_TYPE" "$FIELD_NAME" "leaf"
            fi
        done <<< "$FIELDS"
    else
        echo "No fields found in ${LEAF_HEADER_PATH}. Add fields between FIELDS-BEGIN and FIELDS-END, then re-run."
    fi
fi

# Step 5: Ensure root union header is included in ga_types__implemented.h
IMPLEMENTED_HEADER="${BASE_DIR}/ga_types__implemented.h"
if [ -n "$ROOT_UNION_HEADER_NAME" ] && [ -f "$IMPLEMENTED_HEADER" ]; then
    ROOT_INCLUDE_LINE="#include \"game_action/types/implemented/${ROOT_UNION_DIR_PATH}/${ROOT_UNION_HEADER_NAME}\""
    echo "Ensuring include of ${ROOT_UNION_HEADER_NAME} in ${IMPLEMENTED_HEADER}"
    ensure_include_in_gen_region "$IMPLEMENTED_HEADER" "$ROOT_INCLUDE_LINE" || true
elif [ -n "$ROOT_UNION_HEADER_NAME" ] && [ ! -f "$IMPLEMENTED_HEADER" ]; then
    echo "Warning: ${IMPLEMENTED_HEADER} not found. Cannot add root include."
elif [ ${#DIR_PARTS[@]} -eq 0 ]; then
    # Leaf directly under implemented/ — include the leaf itself
    LEAF_INCLUDE_FOR_ROOT="#include \"game_action/types/implemented/${LEAF_HEADER_NAME}\""
    if [ -f "$IMPLEMENTED_HEADER" ]; then
        echo "Ensuring include of ${LEAF_HEADER_NAME} in ${IMPLEMENTED_HEADER}"
        ensure_include_in_gen_region "$IMPLEMENTED_HEADER" "$LEAF_INCLUDE_FOR_ROOT" || true
    else
        echo "Warning: ${IMPLEMENTED_HEADER} not found. Cannot add root include."
    fi
fi

echo "Done."
