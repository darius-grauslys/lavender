    class Default_Client_Poller {
        <<strategy>>
        +m_poll_tcp_socket_manager_as__client__default()
    }

    class Default_Server_Poller {
        <<strategy>>
        +m_poll_tcp_socket_manager_as__server__default()
    }

    %% Ownership: Game owns clients and TCP_Socket_Manager
    Game *-- "0..*" Client : pM_clients pool
    Game *-- TCP_Socket_Manager : pM_tcp_socket_manager
    Game *-- Session_Token : session_token
    Game *-- Game_Action_Logic_Table : game_action_logic_table

    %% Client owns inbound/outbound game action managers
    Client *-- Game_Action_Manager : game_action_manager__inbound
    Client *-- Game_Action_Manager : game_action_manager__outbound
    Client *-- Client_Flags__u16 : client_flags__u16

    %% Game_Action_Manager owns Game_Actions
    Game_Action_Manager *-- "0..*" Game_Action : game_actions pool

    %% Game_Action_Logic_Table owns entries
    Game_Action_Logic_Table *-- "N" Game_Action_Logic_Entry : per Game_Action_Kind

    %% TCP_Socket_Manager owns TCP_Sockets and references platform context
    TCP_Socket_Manager *-- "0..N" TCP_Socket : tcp_sockets pool
    TCP_Socket_Manager --> PLATFORM_TCP_Context : p_PLATFORM_tcp_context
    TCP_Socket_Manager --> m_Poll_TCP_Socket_Manager : polling callback
    TCP_Socket_Manager --> PLATFORM_TCP_Socket : p_PLATFORM_tcp_socket__pending_connection

    %% TCP_Socket contains packets and references platform socket
    TCP_Socket *-- "0..N" TCP_Packet : queue_of__tcp_packet (circular buffer)
    TCP_Socket *-- IPv4_Address : tcp_socket__address
    TCP_Socket *-- TCP_Socket_Flags__u8 : tcp_socket_flags__u8
    TCP_Socket --> TCP_Socket_State : tcp_socket__state_of
    TCP_Socket --> PLATFORM_TCP_Socket : p_PLATFORM_tcp_socket

    %% Polling strategies implement m_Poll_TCP_Socket_Manager
    Default_Client_Poller ..|> m_Poll_TCP_Socket_Manager : implements
    Default_Server_Poller ..|> m_Poll_TCP_Socket_Manager : implements

    %% Session_Token compresses to entity UUID
    Session_Token ..> Game : compressed UUID for entity allocation

    %% Game_Action references TCP types for multiplayer game actions
    Game_Action --> IPv4_Address : ga_kind__tcp_connect__begin
    Game_Action --> Session_Token : ga_kind__tcp_connect__begin
    Game_Action --> TCP_Packet : TCP_DELIVERY overlay
