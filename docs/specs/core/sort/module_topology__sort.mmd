    %% Ownership: Game owns Sort_List_Manager
    Game *-- Sort_List_Manager : owns

    %% Sort_List_Manager owns pools of Sort_List and Sort_Node
    Sort_List_Manager *-- "0..64" Sort_List : sort_lists pool
    Sort_List_Manager *-- "0..512" Sort_Node : sort_nodes pool

    %% Sort_List references contiguous range of Sort_Nodes
    Sort_List --> "0..*" Sort_Node : p_node_list (contiguous range)

    %% Sort_List contains Sort_Data
    Sort_List *-- Sort_Data : sort_data

    %% Sort_List uses pluggable function pointers
    Sort_List --> f_Sort_Heuristic : f_sort_heuristic
    Sort_List --> m_Sort : m_sort

    %% Sort_List extension chaining
    Sort_List --> Sort_List : p_sort_list__next (extension chain)

    %% Sort_Node index-based linking within contiguous array
    Sort_Node --> Sort_Node : index_for__next_node (index-based link)

    %% Sort_Node holds opaque data pointer
    Sort_Node --> "0..1" Sort_List : p_node_data (when chaining sort lists)

    %% Heap_Sort_Module provides m_Sort implementations
    Heap_Sort_Module ..|> m_Sort : m_sort__heapify__sort_list
    Heap_Sort_Module ..|> m_Sort : m_sort__heap_sort__sort_list

    %% Heap_Sort_Module operates on Sort_List and Sort_Data
    Heap_Sort_Module ..> Sort_List : configures and steps
    Heap_Sort_Module ..> Sort_Data : reads/writes heap indices

    %% Opaque_Heap_Sort_Module is standalone
    Opaque_Heap_Sort_Module --> f_Sort_Heuristic__i32 : comparison function
    Opaque_Heap_Sort_Module --> f_Sort_Swap__Void : swap function

    %% is_sort_node_a__sort_list bridges Sort_Node and Sort_List
    Sort_List_Manager ..> Sort_Node : is_sort_node_a__sort_list checks p_node_data
