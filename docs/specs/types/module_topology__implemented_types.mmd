%% Module Topology: Implemented Types (Template System)
%% Shows the injection hierarchy and relationships between
%% template headers in core/include/types/implemented/.
%%
%% These files are templates shipped with the engine. They are
%% copied to the game project directory by tools/lav_new_project
%% and extended by the game developer. The copies are what
%% participate in the build — not the originals.

classDiagram
    direction TB

    class defines_weak_h {
        <<injection target>>
        +Tile_Kind
        +Entity_Kind
        +Item_Kind
        +Scene_Kind
        +Sprite_Kind
        +Sprite_Animation_Kind
        +Sprite_Animation_Group_Kind
        +Audio_Effect_Kind
        +Audio_Stream_Kind
        +UI_Element_Kind
        +UI_Tile_Kind
        +UI_Sprite_Kind
        +Graphics_Window_Kind
        +Game_Action_Kind
        +Chunk_Generator_Kind
        +Hitbox_Kind
        +Hitbox_Manager_Type
    }

    class defines_h {
        <<injection target>>
        +Tile
        +Entity_Data
        +Entity_Functions
        +Item_Data
        +UI_Element_Data
        +Tile_Logic_Table_Data
        +MAX_QUANTITY_OF__TILE_LOGIC_TABLES
    }

