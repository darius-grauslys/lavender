%% Module Topology: Test Infrastructure
%% Shows ownership hierarchy and relationships between test system components.

classDiagram
    direction TB

    class TestRunner {
        <<munit>>
        +MunitSuite test_suite
        +munit_suite_main(suite, user_data, argc, argv) int
    }

    class main_c {
        <<generated entry point>>
        +main(argc, argv) int
    }

    class test_util_h {
        <<macro library>>
        +TEST_NAME(name)
        +TEST_NAME__SETUP(name)
        +TEST_NAME__CLEAN_UP(name)
        +TEST_FUNCTION(name)
        +SETUP_TEST(name)
        +CLEAN_UP_TEST(name)
        +INCLUDE_TEST(name, options, parameters)
        +INCLUDE_TEST__NO_PARAMETERS(name, options)
        +INCLUDE_TEST__BASIC(name)
        +INCLUDE_TEST__STATELESS(name)
        +DECLARE_SUITE(name)
        +INCLUDE_SUITE(name)
        +DEFINE_SUITE(name, ...)
        +DEFINE_SUITE_WITH__SUB_SUITES(name, ...)
        +INCLUDE_SUB_SUITES(name, count, ...)
        +END_TESTS
        +END_SUITES
        +f_test_suite_includer
        +test_log(c_str__msg, ...)
    }

    class MunitSuite {
        <<munit>>
        +char *prefix
        +MunitTest *tests
        +MunitSuite *suites
        +unsigned int iterations
        +MunitSuiteOptions options
    }

    class MunitTest {
        <<munit>>
        +char *name
        +MunitTestFunc test
        +MunitTestSetup setup
        +MunitTestTearDown tear_down
        +MunitTestOptions options
        +MunitParameterEnum *parameters
    }

    class MunitResult {
        <<munit enum>>
        MUNIT_OK
        MUNIT_FAIL
        MUNIT_SKIP
        MUNIT_ERROR
    }

    class MAIN_TEST_SUITE__CORE_ANCIENTS_GAME_h {
        <<generated root header>>
        includes test_suite_main.h
        includes test_suite_vectors.h
        includes test_suite_core_string.h
        includes test_suite_random.h
        includes test_suite_client.h
        includes test_suite_degree.h
        includes test_suite_game.h
        includes 18 directory MAIN_TEST_SUITE headers
        +DECLARE_SUITE(CORE_ANCIENTS_GAME)
    }

    class MAIN_TEST_SUITE__CORE_ANCIENTS_GAME_c {
        <<generated root source>>
        +test_suite_CORE_ANCIENTS_GAME__sub_suites[26]
        +include_sub_suites_for__CORE_ANCIENTS_GAME(MunitSuite*)
        +include_test_suite__CORE_ANCIENTS_GAME(MunitSuite*)
    }

    class DirectorySuite {
        <<generated per subdirectory>>
        +include_test_suite__TREE_DIRNAME(MunitSuite*)
        +include_sub_suites_for__TREE_DIRNAME(MunitSuite*)
        +test_suite_TREE_DIRNAME__sub_suites[N]
        +test_suite_TREE_DIRNAME__prefix
        +test_suite_TREE_DIRNAME__tests[]
    }

    class ModuleSuiteHeader {
        <<generated per source file>>
        +DECLARE_SUITE(module_name)
    }

    class ModuleSuiteSource {
        <<generated per source file>>
        +test_suite_module__prefix
        +test_suite_module__tests[]
        +include_test_suite__module(MunitSuite*)
    }

    class update_sh {
        <<bash script>>
        +base_dir
        +core_dir
        +platform_dir
        +gen_main(include_dir, source_dir, skip_stubs)
