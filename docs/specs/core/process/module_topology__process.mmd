    %% Ownership: Game owns Process_Manager
    Game *-- Process_Manager : owns

    %% Process_Manager owns process pool and Process_Table
    Process_Manager *-- "512" Process : processes pool
    Process_Manager *-- Process_Table : owns

    %% Process_Table owns priority entries and pointer array
    Process_Table *-- "PROCESS_MAX_PRIORITY_LEVEL + 1" Process_Priority_Table_Entry : process_priority_table
    Process_Table --> "0..512" Process : ptr_array_of__processes (pointers into pool)

    %% Process_Priority_Table_Entry delimits a region of the pointer array
    Process_Priority_Table_Entry --> Process : p_ptr_process__youngest_of__priority
    Process_Priority_Table_Entry --> Process : p_ptr_process__oldest_of__priority
    Process_Priority_Table_Entry --> Process : p_ptr_process__current_priority_to__swap (round-robin cursor)

    %% Process uses enums, flags, handler
    Process --> Process_Status_Kind : the_kind_of_status__this_process_has
    Process --> Process_Kind : the_kind_of__process_this__process_is
    Process *-- Process_Flags__u8 : process_flags__u8
    Process *-- Process_Priority__u8 : process_priority__u8
    Process --> m_Process : m_process_run__handler
    Process --> m_Process : m_process_dispose__handler

    %% Process enqueueing chain
    Process --> Process : p_enqueued_process / p_sub_process

    %% Process opaque data pointer
    Process --> Game_Action : p_process_data (Game_Action mode)
    Process --> Serialization_Request : p_process_data (Serialized / TCP mode)

    %% Game_Action_Process configures Process for game actions
    Game_Action_Process ..> Process : configures
    Game_Action_Process ..> Game_Action : wraps as p_process_data

    %% TCP_Game_Action_Process extends game action process for TCP
    TCP_Game_Action_Process ..> Process : configures
    TCP_Game_Action_Process ..> Serialization_Request : allocates and wraps
    TCP_Game_Action_Process ..> Game_Action : original moved to Serialization_Request.p_data

    %% Filesystem_Process configures Process for file I/O
    Filesystem_Process ..> Process : configures
    Filesystem_Process ..> Serialization_Request : wraps as p_process_data

    %% Serialization_Request data pointer chain
    Serialization_Request --> Game_Action : p_data (in TCP receiver mode)

    %% Process_Manager latest process pattern
    Process_Manager --> Process : p_process__latest (one-shot)
