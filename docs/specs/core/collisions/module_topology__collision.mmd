        <<typedef u8>>
        +HITBOX_FLAG__IS_ACTIVE
        +HITBOX_FLAG__IS_DIRTY
    }

    class Collision_Node_Pool {
        +Collision_Node collision_nodes[QUANTITY_OF__GLOBAL_SPACE]
